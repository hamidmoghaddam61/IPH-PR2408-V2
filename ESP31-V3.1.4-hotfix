// ================================================================
// URL-decode helper
// ================================================================
String getField(const String& body, const String& name) {
  String key = name + "=";
  int pos = body.indexOf(key);
  if (pos < 0) return "";
  int end = body.indexOf('&', pos);
  if (end < 0) end = body.length();
  String val = body.substring(pos + key.length(), end);
  val.replace('+', ' ');
  String out;
  out.reserve(val.length());
  for (int i = 0; i < (int)val.length(); i++) {
    char c = val[i];
    if (c == '%' && i + 2 < (int)val.length()) {
      char h1 = val[i + 1], h2 = val[i + 2];
      auto hexVal = [](char h) -> int {
        if (h >= '0' && h <= '9') return h - '0';
        if (h >= 'A' && h <= 'F') return h - 'A' + 10;
        if (h >= 'a' && h <= 'f') return h - 'a' + 10;
        return -1;
      };
      int hi = hexVal(h1), lo = hexVal(h2);
      if (hi >= 0 && lo >= 0) { out += char((hi << 4) | lo); i += 2; }
      else out += c;
    } else {
      out += c;
    }
  }
  return out;
}

// ================================================================
// formatCurrentTime
// ================================================================
String formatCurrentTime() {
  time_t now = time(nullptr);
  if (now == 0) return "TIME_NOT_SET";
  struct tm t;
  localtime_r(&now, &t);
  char buf[32];
  snprintf(buf, sizeof(buf), "%04d-%02d-%02d %02d:%02d:%02d",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);
  return String(buf);
}

// ================================================================
// Login / Auth
// ================================================================
void handleLoginPost(Stream& client, const String& body) {
  String user = getField(body, "user");
  String pass = getField(body, "pass");
  loadUsersFromPrefs();
  int idx = findUserIndex(user);
  if (idx >= 0 && users[idx].password == pass) {
    isLoggedIn  = true;
    currentUser = user;
    users[idx].lastLogin = formatCurrentTime();
    saveUsersToPrefs();
    client.println("HTTP/1.1 302 Found");
    client.println("Location: /dashboard");
    client.println("Connection: close");
    client.println();
  } else {
    isLoggedIn  = false;
    currentUser = "";
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:نام کاربری یا رمز عبور اشتباه است");
  }
}

void handleSaveAdmin(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  String user  = getField(body, "admin_user");
  String pass1 = getField(body, "admin_pass");
  String pass2 = getField(body, "admin_pass2");
  if (user.isEmpty() || pass1.isEmpty() || pass2.isEmpty()) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:همه فیلدها ضروری هستند."); return;
  }
  if (pass1 != pass2) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:رمز و تکرار آن یکسان نیست."); return;
  }
  setAdminCredentials(user, pass1);
  loadUsersFromPrefs();
  if (primaryAdminIndex < 0 || primaryAdminIndex >= MAX_USERS) primaryAdminIndex = 0;
  users[primaryAdminIndex].username = user;
  users[primaryAdminIndex].password = pass1;
  users[primaryAdminIndex].role     = "admin";
  users[primaryAdminIndex].used     = true;
  saveUsersToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Admin updated. لطفاً یک‌بار logout/login کنید.");
}

void handleForgot(Stream& client, const String& body) {
