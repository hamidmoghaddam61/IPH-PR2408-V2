// ================================================================
// API: Save Network / WiFi / NTP / Customer / Descriptions
// ================================================================
void handleSaveNetwork(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  EthConfig cfg = ethCfg;
  String mode = getField(body, "mode");
  if (mode != "dhcp" && mode != "static") mode = "static";
  cfg.net.ip_mode = mode;
  if (mode == "static") {
    String ipStr   = getField(body, "ip");
    String maskStr = getField(body, "subnet");
    String gwStr   = getField(body, "gw");
    String dnsStr  = getField(body, "dns");
    if (ipStr.length())   cfg.net.ip.fromString(ipStr);
    if (maskStr.length()) cfg.net.subnet.fromString(maskStr);
    if (gwStr.length())   cfg.net.gw.fromString(gwStr);
    if (dnsStr.length())  cfg.net.dns.fromString(dnsStr);
  }
  saveEthConfig(cfg); ethCfg = cfg;
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Network saved. لطفاً دستگاه را ریبوت کنید تا تنظیمات IP اعمال شود.");
}

void handleSaveWifi(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  WifiConfig cfg = wifiCfg;
  String ssid = getField(body, "ssid");
  String pass = getField(body, "pass");
  if (ssid.length()) cfg.ssid = ssid;
  if (pass.length()) cfg.pass = pass;
  saveWifiConfig(cfg); wifiCfg = cfg;
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:WiFi AP saved. با ریست، SSID/PASS جدید فعال می‌شود.");
}

void handleSaveNtp(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  NtpConfig cfg = ntpCfg;
  String s1  = getField(body, "ntp1");
  String s2  = getField(body, "ntp2");
  String gmt = getField(body, "gmtOffset");
  String dst = getField(body, "dstOffset");
  if (s1.length()) cfg.server1 = s1;
  if (s2.length()) cfg.server2 = s2;
  if (gmt.length()) cfg.gmtOffsetSec      = gmt.toInt() * 3600L;
  if (dst.length()) cfg.daylightOffsetSec = dst.toInt() * 3600;
  saveNtpConfig(cfg); ntpCfg = cfg;
  configTime(ntpCfg.gmtOffsetSec, ntpCfg.daylightOffsetSec,
             ntpCfg.server1.c_str(), ntpCfg.server2.c_str());
  // HOTFIX: reset timeSynced تا loop مجدداً sync کند
  timeSynced = false;
  lastNtpSyncAttemptMs = 0;
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:NTP saved & applied.");
}

void handleSaveCustomer(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  CustomerConfig c = custCfg;
  String s;
  s = getField(body, "company");  if (s.length()) c.company  = s;
  s = getField(body, "location"); if (s.length()) c.location = s;
  s = getField(body, "coords");   if (s.length()) c.coords   = s;
  s = getField(body, "mobile1");  if (s.length()) c.mobile1  = s;
  s = getField(body, "mobile2");  if (s.length()) c.mobile2  = s;
  s = getField(body, "mobile3");  if (s.length()) c.mobile3  = s;
  saveCustomerConfig(c); custCfg = c;
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Customer saved.");
}

void handleSaveDescriptions(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  String ports  = getField(body, "ports_desc");
  String relays = getField(body, "relays_desc");
