// ================================================================
// ESP31-V3.1.4-hotfix  –  ESP1 firmware  (IPH-PR2408)
// ================================================================
// hotfix نسبت به V3.1.4 (کامیت f8d8c9b):
//  1. اصلاح پایه‌های UART1 برای ارتباط ESP1↔ESP2:
//       #define ESP2_UART_RX 26   (GPIO26 = RX روی ESP1) ← تأیید شده با تست سخت‌افزاری
//       #define ESP2_UART_TX 25   (GPIO25 = TX روی ESP1)
//       سیم‌کشی مستقیم: GPIO26 ESP1 ↔ GPIO26 ESP2 ، GPIO25 ESP1 ↔ GPIO25 ESP2
//  2. بازگرداندن منطق کامل SMS از V2.4:
//       - پارسر خط‌محور (line-based) در loop برای استخراج sender از +CMT:
//       - processSMS(sender, text) با بررسی مجوز، parseTargetEnglish،
//         parseTimerCommand، setRelayEx/setPortEx، armTwoStageTimer
//       - sendSMS با waitForSIM800 (منتظر پرامپت > و OK می‌ماند)
//  3. NTP پایدار از V2.4:
//       - EthernetUDP ntpUdp, syncTimeWithNtpOverEthernet (non-blocking retry)
//       - در loop: تلاش مجدد هر 15 ثانیه تا sync، سپس هر 6 ساعت
//  4. پایداری Ethernet:
//       - ethernetReinitIfDown بدون reset سخت‌افزاری W5500 (جلوگیری از قطع ناخواسته)
//       - بازه چک Ethernet از 10s به 60s افزایش یافت
//  5. لاگ‌های اضافی در سریال برای تأیید init‌ها (بدون اسپم)
//  6. تمام امکانات V3.1.4 (وبسرور، SD، PWA، پروتکل ESP2) حفظ شده‌اند
// ================================================================

#include <WiFi.h>
#include <Wire.h>
#include <SPI.h>
#include <Ethernet.h>
#include <EthernetUdp.h>
#include <SD.h>
#include <Preferences.h>
#include <TCA9555.h>
#include <time.h>
#include <Update.h>
#include <esp_task_wdt.h>
#include <HardwareSerial.h>

// ================================================================
// پایه‌های سریال ESP2 – اتصال مستقیم (26↔26 , 25↔25)
// ESP1 RX=26 ← سیم ← GPIO26 ESP2 (TX=26)
// ESP1 TX=25 → سیم → GPIO25 ESP2 (RX=25)
// ← تأیید شده با تست مینیمال توسط کاربر
// ================================================================
#define ESP2_UART_RX 26     // GPIO26 = پایه RX روی ESP1  ← HOTFIX (قبلاً 25 بود - اشتباه)
#define ESP2_UART_TX 25     // GPIO25 = پایه TX روی ESP1  ← HOTFIX (قبلاً 26 بود - اشتباه)
#define ESP2_RS485_DE_RE 33

// ---------- SIM800 (UART2) ----------
HardwareSerial sim800(2);
// smsBuffer/smsIncoming حذف شدند – HOTFIX از پارسر خط‌محور V2.4 استفاده می‌کند
#define SIM800_RX 16
#define SIM800_TX 17

// ---------- Wi‑Fi AP ----------
const char* AP_SSID_DEFAULT = "IPH-PR2408";
const char* AP_PASS_DEFAULT = "1234567890";

WiFiServer wifiServer(80);

// ---------- Ethernet / W5500 ----------
#define W5500_CS  5
#define W5500_RST 27

byte mac[]        = { 0xDE, 0xAD, 0xBE, 0xEF, 0x55, 0x00 };
IPAddress ipDefault(192, 168, 0, 20);
IPAddress gwDefault(192, 168, 0, 1);
IPAddress subnetDefault(255, 255, 255, 0);
IPAddress dnsDefault(192, 168, 0, 1);

EthernetServer ethServer(80);
EthernetUDP    Udp;
EthernetUDP    ntpUdp;             // HOTFIX: NTP از طریق Ethernet (نه WiFi configTime)
bool           timeSynced = false; // HOTFIX: flag sync موفق NTP
unsigned long  lastNtpSyncAttemptMs = 0; // HOTFIX: زمان آخرین تلاش NTP
IPAddress      hbGateway;
unsigned long  lastHeartbeat = 0;
unsigned long  lastLinkCheck = 0;
bool           ethernetOk    = true;

// ---------- SD روی HSPI ----------
SPIClass hspi(HSPI);
#define SD_CS 15

// ---------- PCA9555 ----------
#define PCA1_ADDR       0x20
#define PCA2_ADDR       0x21
#define RELAY_CH_COUNT  32

TCA9555 p1(PCA1_ADDR);
TCA9555 p2(PCA2_ADDR);

bool relayState[RELAY_CH_COUNT];

