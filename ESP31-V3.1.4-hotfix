}

// ================================================================
// Users API
// ================================================================
void handleUsersListApi(Stream& client) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  loadUsersFromPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: application/json; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("[");
  bool first = true;
  for (int i = 0; i < MAX_USERS; i++) {
    if (!users[i].used) continue;
    if (!first) client.print(",");
    first = false;
    client.print("{\"username\":\"");
    String u = users[i].username; u.replace("\\","\\\\"); u.replace("\"","\\\""); client.print(u);
    client.print("\",\"role\":\""); client.print(users[i].role);
    client.print("\",\"lastLogin\":\"");
    String l = users[i].lastLogin; l.replace("\\","\\\\"); l.replace("\"","\\\""); client.print(l);
    client.print("\",\"primary\":"); client.print(i == primaryAdminIndex ? "true" : "false");
    client.print("}");
  }
  client.print("]");
}

void handleAddUserApi(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  loadUsersFromPrefs();
  String user = getField(body, "user");
  String pass = getField(body, "pass");
  String role = getField(body, "role");
  if (role != "admin" && role != "viewer") role = "viewer";
  if (user.length() == 0 || pass.length() == 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:نام کاربری و رمز عبور الزامی است."); return;
  }
  if (findUserIndex(user) >= 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:این نام کاربری قبلاً ثبت شده است."); return;
  }
  int slot = findFreeUserSlot();
  if (slot < 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:حداکثر تعداد کاربران (10) پر شده است."); return;
  }
  users[slot] = { user, pass, role, "", true };
  saveUsersToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:کاربر جدید اضافه شد.");
}

void handleUpdateUserApi(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  loadUsersFromPrefs();
  String oldUser = getField(body, "oldUser");
  String newUser = getField(body, "user");
  String pass    = getField(body, "pass");
  String role    = getField(body, "role");
  if (role != "admin" && role != "viewer") role = "viewer";
  int idx = findUserIndex(oldUser);
  if (idx < 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:کاربر پیدا نشد."); return;
  }
  if (newUser != oldUser && findUserIndex(newUser) >= 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:نام کاربری جدید تکراری است."); return;
  }
  if (newUser.length() == 0) newUser = oldUser;
  if (pass.length() == 0)   pass    = users[idx].password;
  users[idx].username = newUser;
  users[idx].password = pass;
  users[idx].role     = (idx == primaryAdminIndex) ? "admin" : role;
  saveUsersToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:کاربر به‌روزرسانی شد.");
}

void handleDeleteUserApi(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  loadUsersFromPrefs();
  String user = getField(body, "user");
  int idx = findUserIndex(user);
  if (idx < 0) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:کاربر پیدا نشد."); return;
  }
  if (idx == primaryAdminIndex) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:حذف ادمین اصلی مجاز نیست."); return;
  }
  users[idx] = { "", "", "", "", false };
  saveUsersToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:کاربر حذف شد.");
}

// ================================================================
// Device Info / Reboot / Factory Reset
// ================================================================
String getDeviceSerial() {
  uint64_t chipid = ESP.getEfuseMac();
  char buf[20];
  snprintf(buf, sizeof(buf), "%04X%08X", (uint16_t)(chipid >> 32), (uint32_t)chipid);
  return String(buf);
}

void handleDeviceInfo(Stream& client) {
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: application/json; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("{\"name\":\"PoE Rackmount\",\"model\":\"IPH-PR2408\",");
  client.print("\"hw\":\"V1.7\",\"fw\":\"V3.1.4-hotfix\",\"serial\":\"");
  client.print(getDeviceSerial()); client.println("\"}");
}

void handleReboot(Stream& client) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println(); client.print("Rebooting...");
  client.flush(); delay(200); ESP.restart();
}

void handleFactoryReset(Stream& client, const String& body) {
  (void)body;
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  const char* ns[] = { "eth", "wifi", "ntp", "cust", "relays", "users" };
  for (auto n : ns) { preferences.begin(n, false); preferences.clear(); preferences.end(); }
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Factory reset done. لطفاً دستگاه را ریبوت کنید.");
}

// ================================================================
// OTA Firmware Upload (raw binary via curl)
// ================================================================
void handleFirmwareUpload(Stream& client, const String& header, const String& body) {
  (void)header; (void)body;
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("ERROR:از endpoint /api/uploadFirmwareRaw با curl استفاده کنید.");
}

void handleFirmwareRaw(Stream& client, const String& header, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  String clKey = "Content-Length:";
  int clPos = header.indexOf(clKey);
  int contentLen = body.length();
  if (clPos >= 0) {
    int lineEnd = header.indexOf("\r\n", clPos);
    if (lineEnd < 0) lineEnd = header.length();
    String clStr = header.substring(clPos + clKey.length(), lineEnd);
    clStr.trim();
    int v = clStr.toInt();
    if (v > 0) contentLen = v;
  }
  Serial.print("RAW firmware upload, body size="); Serial.println(body.length());
  Serial.print("Content-Length="); Serial.println(contentLen);
  if (contentLen <= 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:Content-Length نامعتبر است."); return;
  }
  if (!Update.begin(contentLen)) {
    client.println("HTTP/1.1 500 Internal Server Error"); client.println("Connection: close"); client.println();
    client.print("ERROR:Update.begin failed"); return;
  }
  int remaining = contentLen;
  if (body.length() > 0) {
    int chunk = min((int)body.length(), remaining);
    size_t written = Update.write((uint8_t*)body.c_str(), chunk);
    if (written != (size_t)chunk) {
      Update.abort();
      client.println("HTTP/1.1 500 Internal Server Error"); client.println("Connection: close"); client.println();
      client.print("ERROR:Update.write failed"); return;
    }
    remaining -= chunk;
  }
  while (remaining > 0) {
    if (!client.available()) { delay(1); continue; }
    int c = client.read();
    if (c < 0) {
      Update.abort();
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
      client.print("ERROR:داده کامل دریافت نشد."); return;
    }
    uint8_t b = (uint8_t)c;
    if (Update.write(&b, 1) != 1) {
      Update.abort();
      client.println("HTTP/1.1 500 Internal Server Error"); client.println("Connection: close"); client.println();
      client.print("ERROR:Update.write failed"); return;
    }
    remaining--;
  }
  if (!Update.end(true)) {
    client.println("HTTP/1.1 500 Internal Server Error"); client.println("Connection: close"); client.println();
    client.print("ERROR:Update.end failed"); return;
  }
  Serial.println("RAW Update success.");
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Firmware uploaded via RAW. لطفاً دستگاه را ریبوت کنید.");
}

// ================================================================
// Web File Upload روی SD
// ================================================================
void handleUploadWebFile(Stream& client, const String& header,
                         const String& body, const String& firstLine) {
  if (firstLine.indexOf("key=1234") < 0) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:کلید آپلود وب نامعتبر است."); return;
  }
  int pathStart = firstLine.indexOf(' ');
  int pathEnd   = firstLine.indexOf(' ', pathStart + 1);
  if (pathStart < 0 || pathEnd < 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:خطا در تجزیه firstLine."); return;
  }
  String pathPart = firstLine.substring(pathStart + 1, pathEnd);
  int    qPos     = pathPart.indexOf('?');
  String query    = (qPos >= 0) ? pathPart.substring(qPos + 1) : "";
  String fileName = "";
  if (query.length() > 0) {
    int nPos = query.indexOf("name=");
    if (nPos >= 0) {
      int start = nPos + 5;
      int amp   = query.indexOf('&', start);
      if (amp < 0) amp = query.length();
      fileName = query.substring(start, amp);
    }
  }
  if (fileName.length() == 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:پارامتر name یافت نشد."); return;
  }
  if (!fileName.startsWith("/")) fileName = "/" + fileName;
  if (fileName.indexOf("..") >= 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:نام فایل نامعتبر است."); return;
  }
  Serial.print("Upload web file to: "); Serial.println(fileName);
  String clKey = "Content-Length:";
  int clPos    = header.indexOf(clKey);
  int contentLen = body.length();
  if (clPos >= 0) {
    int lineEnd = header.indexOf("\r\n", clPos);
    if (lineEnd < 0) lineEnd = header.length();
    String clStr = header.substring(clPos + clKey.length(), lineEnd);
    clStr.trim();
    int v = clStr.toInt();
    if (v > 0) contentLen = v;
  }
  if (contentLen <= 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:Content-Length نامعتبر است."); return;
  }
  SD.remove(fileName);
  File f = SD.open(fileName, FILE_WRITE);
  if (!f) {
    client.println("HTTP/1.1 500 Internal Server Error"); client.println("Connection: close"); client.println();
    client.print("ERROR:باز کردن فایل برای نوشتن ناموفق بود."); return;
  }
  int remaining = contentLen;
  if (body.length() > 0) {
    int chunk = min((int)body.length(), remaining);
    if (chunk > 0) { f.write((const uint8_t*)body.c_str(), chunk); remaining -= chunk; }
  }
  while (remaining > 0) {
    if (!client.available()) { delay(1); continue; }
    int c = client.read();
    if (c < 0) {
      f.close();
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
      client.print("ERROR:داده کامل دریافت نشد."); return;
    }
    uint8_t b = (uint8_t)c;
    f.write(&b, 1); remaining--;
  }
  f.close();
  Serial.print("Web file uploaded OK, size="); Serial.println(contentLen);
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Web file uploaded.");
}

// ================================================================
// Log (relay.log) – اصلاح‌شده: استریم به‌جای بارگذاری در حافظه
// ================================================================
void ensureRelayLogHeader() {
  if (!SD.exists("/relay.log")) {
    File f = SD.open("/relay.log", FILE_WRITE);
    if (!f) return;
    f.println("DATETIME            |  USER       |  PORT/RELAY  |  ACTION        |  STATE");
    f.close();
  }
}

void appendRelayLog(const char* action, int ch) {
  File f = SD.open("/relay.log", FILE_APPEND);
  if (!f) return;
  time_t now = time(nullptr);
  struct tm t;
  localtime_r(&now, &t);
  char ts[32];
  snprintf(ts, sizeof(ts), "%04d-%02d-%02d %02d:%02d:%02d",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);
  const char* type;
  int index;
  if (ch >= 0 && ch < 24) { type = "PORT";  index = ch + 1; }
  else                     { type = "RELAY"; index = ch - 24 + 1; }
  String user = currentUser.length() ? currentUser : getUsername();
  const char* state = relayState[ch] ? "ON" : "OFF";
  f.print(ts); f.print("  |  user="); f.print(user);
  f.print("  |  "); f.print(type); f.print("="); f.print(index);
  f.print("  |  action="); f.print(action);
  f.print("  |  state="); f.println(state);
  f.close();
}

// HOTFIX: نسخه با actor مشخص (برای SMS و timer SMS)
void appendRelayLogWithActor(const char* action, int ch, const String& actor) {
  File f = SD.open("/relay.log", FILE_APPEND);
  if (!f) return;
  time_t now = time(nullptr);
  struct tm t;
  localtime_r(&now, &t);
  char ts[32];
  snprintf(ts, sizeof(ts), "%04d-%02d-%02d %02d:%02d:%02d",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);
  const char* type;
  int index;
  if (ch >= 0 && ch < 24) { type = "PORT";  index = ch + 1; }
  else                     { type = "RELAY"; index = ch - 24 + 1; }
  const char* state = relayState[ch] ? "ON" : "OFF";
  f.print(ts); f.print("  |  user="); f.print(actor);
  f.print("  |  "); f.print(type); f.print("="); f.print(index);
  f.print("  |  action="); f.print(action);
  f.print("  |  state="); f.println(state);
  f.close();
}

void handleRelayLogApi(Stream& client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println(); client.print("ERROR:Forbidden"); return;
  }
  File f = SD.open("/relay.log", FILE_READ);
  if (!f) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println(); client.print("NO_LOG"); return;
  }
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  // استریم مستقیم فایل – بدون بارگذاری در حافظه (رفع memory leak)
  static uint8_t logBuf[512];
  while (true) {
    int n = f.read(logBuf, sizeof(logBuf));
    if (n <= 0) break;
    client.write(logBuf, n);
    esp_task_wdt_reset();
  }
  f.close();
}

// ================================================================
// Timer API
// ================================================================
void handleSetTimer(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  String targetStr = getField(body, "target");
  String firstStr  = getField(body, "first");
  String durStr    = getField(body, "duration");
  String secondStr = getField(body, "second");
  if (targetStr.length() < 2) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:هدف نامعتبر است"); return;
  }
  char tType = targetStr.charAt(0);
  int  index = targetStr.substring(1).toInt();
  int  ch    = -1;
  if (tType == 'P') {
    if (index < 1 || index > 24) {
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
      client.print("ERROR:شماره پورت نامعتبر است"); return;
    }
    ch = index - 1;
  } else if (tType == 'R') {
    if (index < 1 || index > 8) {
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
      client.print("ERROR:شماره رله نامعتبر است"); return;
    }
    ch = 24 + (index - 1);
  } else {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    client.print("ERROR:هدف نامعتبر است"); return;
  }
  unsigned long sec = durStr.toInt();
  if (sec == 0) sec = 1;
  simpleTimer = { true, ch, (firstStr == "on"), (secondStr == "on"), millis(), sec * 1000UL, currentUser };
  relayState[ch] = simpleTimer.firstState;
  applyAllOutputs(); saveRelayStateToPrefs(); appendRelayLog("timer_first", ch);
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Timer set.");
}

void checkSimpleTimer() {
  if (!simpleTimer.active) return;
  if ((millis() - simpleTimer.startMs) >= simpleTimer.delayMs) {
    relayState[simpleTimer.channel] = simpleTimer.secondState;
    applyAllOutputs(); saveRelayStateToPrefs();
    appendRelayLog("timer_second", simpleTimer.channel);
    simpleTimer.active = false;
  }
}

// ================================================================
// Tooltip APIs
// ================================================================
void handleTooltipsGet(Stream& client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:Forbidden"); return;
  }
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: application/json; charset=utf-8");
  client.println("Connection: close"); client.println();
  auto printEntry = [&client](TooltipEntry* arr, int count, const char* key) {
    client.print("{\""); client.print(key); client.print("\":[");
    for (int i = 0; i < count; i++) {
      if (i > 0) client.print(",");
      TooltipEntry& e = arr[i];
      client.print("{\"id\":"); client.print((int)e.index); client.print(",\"texts\":[");
      for (int j = 0; j < 5; j++) {
        if (j > 0) client.print(",");
        client.print("\"");
        String t = e.texts[j]; t.replace("\\","\\\\"); t.replace("\"","\\\"");
        client.print(t); client.print("\"");
      }
      client.print("]}");
    }
    client.print("]");
  };
  client.print("{");
  client.print("\"ports\":[");
  for (int i = 0; i < 24; i++) {
    if (i > 0) client.print(",");
    TooltipEntry& e = portTooltips[i];
    client.print("{\"id\":"); client.print((int)e.index); client.print(",\"texts\":[");
    for (int j = 0; j < 5; j++) {
      if (j > 0) client.print(",");
      client.print("\"");
      String t = e.texts[j]; t.replace("\\","\\\\"); t.replace("\"","\\\"");
      client.print(t); client.print("\"");
    }
    client.print("]}");
  }
  client.print("],\"relays\":[");
  for (int i = 0; i < 8; i++) {
    if (i > 0) client.print(",");
    TooltipEntry& e = relayTooltips[i];
    client.print("{\"id\":"); client.print((int)e.index); client.print(",\"texts\":[");
    for (int j = 0; j < 5; j++) {
      if (j > 0) client.print(",");
      client.print("\"");
      String t = e.texts[j]; t.replace("\\","\\\\"); t.replace("\"","\\\"");
      client.print(t); client.print("\"");
    }
    client.print("]}");
  }
  client.print("]}");
  (void)printEntry;
}

void handleTooltipsSave(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  initTooltipArrays();
  for (int i = 0; i < 24; i++) {
    TooltipEntry& e = portTooltips[i];
    for (int j = 0; j < 5; j++) e.texts[j] = getField(body, "P" + String(e.index) + "_" + String(j));
  }
  for (int i = 0; i < 8; i++) {
    TooltipEntry& e = relayTooltips[i];
    for (int j = 0; j < 5; j++) e.texts[j] = getField(body, "R" + String(e.index) + "_" + String(j));
  }
  saveTooltipsToFile();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.print("OK:Tooltips saved.");
}

// ================================================================
// Toggle
// ================================================================
void toggleRelay(int ch) {
  if (ch < 0 || ch >= RELAY_CH_COUNT) return;
  relayState[ch] = !relayState[ch];
  applyAllOutputs(); saveRelayStateToPrefs(); appendRelayLog("toggle", ch);
}

void handleToggleAllPorts(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  bool on = (getField(body, "mode") == "on");
  for (int ch = 0; ch < 24; ch++) { relayState[ch] = on; appendRelayLog(on ? "all_ports_on" : "all_ports_off", ch); }
  applyAllOutputs(); saveRelayStateToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println(); client.print("OK");
}

void handleToggleAllRelays(Stream& client, const String& body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Connection: close"); client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است."); return;
  }
  bool on = (getField(body, "mode") == "on");
  for (int ch = 24; ch < 32; ch++) { relayState[ch] = on; appendRelayLog(on ? "all_relays_on" : "all_relays_off", ch); }
  applyAllOutputs(); saveRelayStateToPrefs();
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println(); client.print("OK");
}

void handleToggle(Stream& client, const String& firstLine) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println();
    client.print("ERROR:فقط ادمین می‌تواند وضعیت پورت‌ها را تغییر دهد."); return;
  }
  int chPos = firstLine.indexOf("ch=");
  if (chPos < 0) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println(); return;
  }
  int endPos = firstLine.indexOf(' ', chPos);
  if (endPos < 0) endPos = firstLine.length();
  int ch = firstLine.substring(chPos + 3, endPos).toInt();
  if (ch < 0 || ch >= RELAY_CH_COUNT) {
    client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println(); return;
  }
  toggleRelay(ch);
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println(); client.print("OK");
}

// ================================================================
// ESP2 API handlers
// ================================================================
void handleEsp2PingApi(Stream& client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println(); client.println("ERROR:Forbidden"); return;
  }
  bool ok = esp2Link.sendWithAck(Esp2Link::MSG_PING, nullptr, 0, 150, 3);
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.println(ok ? "OK:PONG" : "ERROR:TIMEOUT");
}

void handleEsp2TelemApi(Stream& client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden"); client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println(); client.println("ERROR:Forbidden"); return;
  }
  bool ok = esp2Link.sendWithAck(Esp2Link::MSG_TELEM_REQ, nullptr, 0, 200, 3);
  client.println("HTTP/1.1 200 OK"); client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close"); client.println();
  client.println(ok ? "OK:TELEM_REQ_SENT" : "ERROR:TIMEOUT");
}

// ================================================================
// SMS (SIM800) – HOTFIX: منطق کامل از V2.4
// ================================================================

// ---------- کمک‌کننده‌های تلفن و SMS ----------
static bool endsWithWord(const String &s, const String &w) {
  if (s.length() < w.length()) return false;
  return s.substring(s.length() - w.length()) == w;
}

String normalizePhone(String s) {
  s.trim(); s.replace(" ", ""); s.replace("-", "");
  if (s.startsWith("0098")) s = "0" + s.substring(4);
  if (s.startsWith("+98"))  s = "0" + s.substring(3);
  if (s.startsWith("98") && s.length() >= 12) s = "0" + s.substring(2);
  if (s.length() == 10 && s.charAt(0) == '9') s = "0" + s;
  if (s.length() != 11 || s.charAt(0) != '0') return s;
  for (int i = 0; i < (int)s.length(); i++) if (!isDigit(s.charAt(i))) return s;
  return s;
}

String normalizeSpaces(String s) {
  s.trim();
  while (s.indexOf("  ") >= 0) s.replace("  ", " ");
  return s;
}

String toInternationalForSim800(String s) {
  s = normalizePhone(s);
  if (s.length() == 11 && s.startsWith("0")) return String("+98") + s.substring(1);
  return s;
}

bool isAuthorizedPhone(const String &senderRaw) {
  String sender = normalizePhone(senderRaw);
  if (sender.length() != 11) return false;
  String m1 = normalizePhone(custCfg.mobile1);
  String m2 = normalizePhone(custCfg.mobile2);
  String m3 = normalizePhone(custCfg.mobile3);
  if (m1.length() == 11 && sender == m1) return true;
  if (m2.length() == 11 && sender == m2) return true;
  if (m3.length() == 11 && sender == m3) return true;
  return false;
}

// وضعیت پورت‌ها و رله‌ها
String getStatus() {
  String s = "STATUS\nP:";
  for (int i = 0; i < 24; i++) s += (relayState[i] ? '1' : '0');
  s += "\nR:";
  for (int i = 24; i < 32; i++) s += (relayState[i] ? '1' : '0');
  return s;
}

// R1..R8 -> channels 24..31
SetResult setRelayEx(int num, bool state) {
  if (num < 1 || num > 8) return SetResult::Already;
  int ch = 24 + (num - 1);
  if (relayState[ch] == state) return SetResult::Already;
  relayState[ch] = state;
  applyAllOutputs(); saveRelayStateToPrefs();
  return SetResult::Changed;
}

// P1..P24 -> channels 0..23
SetResult setPortEx(int num, bool state) {
  if (num < 1 || num > 24) return SetResult::Already;
  int ch = (num - 1);
  if (relayState[ch] == state) return SetResult::Already;
  relayState[ch] = state;
  applyAllOutputs(); saveRelayStateToPrefs();
  return SetResult::Changed;
}

// پارس فرمان انگلیسی: P1 ON / R2 OFF / PORT 3 ON / RELAY 2 OFF
bool parseTargetEnglish(const String &sms, char &typeOut, int &numOut, bool &stateOut) {
  String up = sms; up.trim(); up.toUpperCase(); up = normalizeSpaces(up);
  if (endsWithWord(up, " ON"))       stateOut = true;
  else if (endsWithWord(up, " OFF")) stateOut = false;
  else return false;
  if (stateOut) up = up.substring(0, up.length() - 3);
  else          up = up.substring(0, up.length() - 4);
  up.trim();
  if (up.startsWith("P") || up.startsWith("R")) {
    typeOut = up.charAt(0);
    String numStr = up.substring(1); numStr.trim();
    if (numStr.length() == 0) return false;
    for (int i = 0; i < (int)numStr.length(); i++) if (!isDigit(numStr.charAt(i))) return false;
    numOut = numStr.toInt();
    return (typeOut == 'P' || typeOut == 'R');
  }
  if (up.startsWith("PORT "))  { typeOut = 'P'; String n = up.substring(5);  n.trim(); numOut = n.toInt(); return (numOut > 0); }
  if (up.startsWith("RELAY ")) { typeOut = 'R'; String n = up.substring(6);  n.trim(); numOut = n.toInt(); return (numOut > 0); }
  return false;
}

// تایمر دو مرحله‌ای: "P1 OFF T5 ON" یا "R2 ON T30 OFF"
bool parseTimerCommand(const String &smsIn,
                       char &typeOut, int &numOut,
                       bool &firstStateOut,
                       unsigned long &delayMsOut,
                       bool &secondStateOut) {
  String s = smsIn; s.trim(); s.toUpperCase(); s = normalizeSpaces(s);
  int tPos = s.indexOf(" T");
  if (tPos < 0) return false;
  String left = s.substring(0, tPos); left.trim();
  String rest = s.substring(tPos + 1); rest.trim();
  char t1 = 0; int n1 = 0; bool st1 = false;
  if (!parseTargetEnglish(left, t1, n1, st1)) return false;
  if (!rest.startsWith("T")) return false;
  rest = rest.substring(1); rest.trim();
  int sp = rest.indexOf(' ');
  if (sp < 0) return false;
  String secStr = rest.substring(0, sp); secStr.trim();
  long sec = secStr.toInt(); if (sec <= 0) sec = 1;
  String st2s = rest.substring(sp + 1); st2s.trim();
  bool st2;
  if (st2s == "ON") st2 = true;
  else if (st2s == "OFF") st2 = false;
  else return false;
  typeOut = t1; numOut = n1; firstStateOut = st1;
  delayMsOut = (unsigned long)sec * 1000UL; secondStateOut = st2;
  return true;
}

// تایمر دو مرحله‌ای با actor
bool armTwoStageTimer(char type, int num, bool firstState, unsigned long delayMs,
                      bool secondState, const String &actor) {
  int ch = -1;
  if (type == 'P') { if (num < 1 || num > 24) return false; ch = num - 1; }
  else if (type == 'R') { if (num < 1 || num > 8) return false; ch = 24 + (num - 1); }
  else return false;
  simpleTimer.active      = true;
  simpleTimer.channel     = ch;
  simpleTimer.firstState  = firstState;
  simpleTimer.secondState = secondState;
  simpleTimer.startMs     = millis();
  simpleTimer.delayMs     = delayMs;
  simpleTimer.actor       = actor;
  relayState[ch] = firstState;
  applyAllOutputs(); saveRelayStateToPrefs();
  appendRelayLogWithActor("sms_timer_first", ch, actor);
  return true;
}

// ---------- ارسال SMS با انتظار برای پرامپت ----------
static bool waitForSIM800(const char* token, uint32_t timeoutMs) {
  uint32_t start = millis();
  String buf = "";
  while (millis() - start < timeoutMs) {
    while (sim800.available()) {
      char c = (char)sim800.read();
      buf += c;
      if (buf.length() > 300) buf.remove(0, 150);
      if (buf.indexOf(token) >= 0) return true;
    }
    esp_task_wdt_reset();
    delay(1);
  }
  return false;
}

void sendSMS(String number, String text) {
  Serial.println("[SIM800] Sending SMS to " + number);
  sim800.println("AT+CMGF=1");
  waitForSIM800("OK", 2000);
  sim800.print("AT+CMGS=\"");
  sim800.print(number);
  sim800.println("\"");
  if (!waitForSIM800(">", 5000)) {
    Serial.println("[SIM800] No > prompt");
    return;
  }
  sim800.print(text);
  sim800.write(26); // Ctrl+Z
  bool ok1 = waitForSIM800("+CMGS:", 15000);
  bool ok2 = waitForSIM800("OK",     15000);
  Serial.print("[SIM800] SMS result: ");
  Serial.print(ok1 ? "CMGS " : "");
  Serial.println(ok2 ? "OK" : "NO_OK");
}

// ---------- پردازش SMS با authorization کامل ----------
void processSMS(const String &senderRaw, String sms) {
  sms.trim();
  if (sms.length() == 0) return;

  String sender = normalizePhone(senderRaw);
  Serial.print("[SMS] FROM: "); Serial.print(sender);
  Serial.print(" TEXT: ");      Serial.println(sms);

  if (!isAuthorizedPhone(sender)) {
    Serial.println("[SMS] ignored (unauthorized).");
    return;
  }

  String replyTo = toInternationalForSim800(sender);

  // STATUS
  if (sms.indexOf("وضعیت") != -1 || sms.indexOf("STATUS") != -1 || sms.indexOf("status") != -1) {
    sendSMS(replyTo, getStatus());
    return;
  }

  // تایمر دو مرحله‌ای
  {
    char t; int num; bool st1; unsigned long dms; bool st2;
    if (parseTimerCommand(sms, t, num, st1, dms, st2)) {
      String actor = normalizePhone(senderRaw);
      bool ok = armTwoStageTimer(t, num, st1, dms, st2, actor);
      if (!ok) {
        sendSMS(replyTo, "ERROR: bad timer target");
      } else {
        String msg = "OK:TIMER ";
        msg += t; msg += String(num);
        msg += (st1 ? " ON " : " OFF "); msg += "T";
        msg += String(dms / 1000); msg += (st2 ? " ON" : " OFF");
        sendSMS(replyTo, msg);
      }
      return;
    }
  }

  // ON/OFF معمولی
  char t = 0; int num = 0; bool state = false;
  if (parseTargetEnglish(sms, t, num, state)) {
    if (t == 'P') {
      if (num < 1 || num > 24) { sendSMS(replyTo, "ERROR: P1..P24"); return; }
      SetResult r = setPortEx(num, state);
      int ch = num - 1;
      if (r == SetResult::Already) {
        sendSMS(replyTo, String("INFO:P") + num + (state ? " already ON" : " already OFF"));
      } else {
        appendRelayLogWithActor("sms_set", ch, normalizePhone(senderRaw));
        sendSMS(replyTo, String("OK:P") + num + (state ? " ON" : " OFF"));
      }
      return;
    }
    if (t == 'R') {
      if (num < 1 || num > 8) { sendSMS(replyTo, "ERROR: R1..R8"); return; }
      SetResult r = setRelayEx(num, state);
      int ch = 24 + (num - 1);
      if (r == SetResult::Already) {
        sendSMS(replyTo, String("INFO:R") + num + (state ? " already ON" : " already OFF"));
      } else {
        appendRelayLogWithActor("sms_set", ch, normalizePhone(senderRaw));
        sendSMS(replyTo, String("OK:R") + num + (state ? " ON" : " OFF"));
      }
      return;
    }
  }

  // راهنما
  sendSMS(replyTo,
    "CMD:\n"
    "STATUS\n"
    "P1 ON|OFF\n"
    "R1 ON|OFF\n"
    "P1 OFF T5 ON"
  );
}

// ================================================================
// NTP از طریق Ethernet – HOTFIX از V2.4
// ================================================================
static uint32_t readU32BE_ntp(const uint8_t *p) {
  return ((uint32_t)p[0] << 24) | ((uint32_t)p[1] << 16) | ((uint32_t)p[2] << 8) | (uint32_t)p[3];
}

bool syncTimeWithNtpOverEthernet(const char* server, uint16_t localPort = 2390, uint32_t timeoutMs = 1500) {
  if (!server || !server[0]) return false;
  IPAddress ntpIP;
  if (!ntpIP.fromString(server)) {
    Serial.print("[NTP] Server must be IP (DNS not supported): ");
    Serial.println(server);
    return false;
  }
  if (ntpUdp.localPort() == 0) ntpUdp.begin(localPort);

  uint8_t pkt[48] = {0};
  pkt[0] = 0b11100011; pkt[1] = 0; pkt[2] = 6; pkt[3] = 0xEC;
  ntpUdp.beginPacket(ntpIP, 123);
  ntpUdp.write(pkt, sizeof(pkt));
  ntpUdp.endPacket();

  uint32_t start = millis();
  while (millis() - start < timeoutMs) {
    int size = ntpUdp.parsePacket();
    if (size >= 48) {
      uint8_t resp[48];
      ntpUdp.read(resp, 48);
      uint32_t secs1900 = readU32BE_ntp(resp + 40);
      if (secs1900 < 2208988800UL) return false;
      uint32_t unixSecs = secs1900 - 2208988800UL;
      timeval tv; tv.tv_sec = unixSecs; tv.tv_usec = 0;
      settimeofday(&tv, nullptr);
      timeSynced = true;
      Serial.print("[NTP] Synced OK. IP="); Serial.print(ntpIP);
      Serial.print(" unix="); Serial.println((unsigned long)unixSecs);
      return true;
    }
    delay(10); yield();
  }
  Serial.println("[NTP] Timeout.");
  return false;
}

// ================================================================
// HTTP Router
// ================================================================
template<typename ClientType>
void handleClient(ClientType& client) {
  if (!client) return;

  String header, body;
  header.reserve(2048);
  body.reserve(1024);

  bool          headerEnded = false;
  unsigned long start       = millis();

  const uint32_t READ_TIMEOUT_MS = 2000;
  const size_t   MAX_HEADER      = 4096;
  const size_t   MAX_BODY        = 4096;

  while (client.connected() && (millis() - start < READ_TIMEOUT_MS)) {
    while (client.available()) {
      char c = (char)client.read();
      if (!headerEnded) {
        if (header.length() < MAX_HEADER) header += c;
        if (header.endsWith("\r\n\r\n")) headerEnded = true;
      } else {
        if (body.length() < MAX_BODY) body += c;
      }
    }
    if (headerEnded) break;
    esp_task_wdt_reset();
    delay(0);
  }

  if (!headerEnded) { client.stop(); return; }

  int    lineEnd   = header.indexOf("\r\n");
  String firstLine = (lineEnd > 0) ? header.substring(0, lineEnd) : header;

  // ---- صفحات ----
  if      (firstLine.startsWith("GET / ")       || firstLine.startsWith("GET /login "))  handleLoginPage(client);
  else if (firstLine.startsWith("POST /login"))          handleLoginPost(client, body);
  else if (firstLine.startsWith("POST /forgot"))         handleForgot(client, body);
  else if (firstLine.startsWith("GET /logout"))          handleLogout(client);
  else if (firstLine.startsWith("GET /dashboard"))       handleDashboard(client);
  else if (firstLine.startsWith("GET /settings"))        handleSettingsPage(client);
  else if (firstLine.startsWith("GET /log"))             handleLogPage(client);
  else if (firstLine.startsWith("GET /timer"))           handleTimerPage(client);
  else if (firstLine.startsWith("GET /tooltip"))         handleTooltipPage(client);
  // ---- استاتیک ----
  else if (firstLine.startsWith("GET /css/style.css"))   sendFile(client, "/css/style.css", "text/css; charset=utf-8");
  else if (firstLine.startsWith("GET /img/")) {
    int sp  = firstLine.indexOf("GET ");
    int sp2 = firstLine.indexOf(' ', sp + 4);
    if (sp >= 0 && sp2 > sp + 4) {
      String path = firstLine.substring(sp + 4, sp2);
      sendFile(client, path.c_str(), path.endsWith(".png") ? "image/png" : guessMimeFromPath(path));
    } else {
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    }
  }
  // ---- PWA (/m) ----
  else if (firstLine.startsWith("GET /m ")    ||
           firstLine.startsWith("GET /m/ ")   ||
           firstLine.startsWith("GET /m?"))   sendFile(client, "/m/index.html", "text/html; charset=utf-8");
  // PWA aliases (iOS standalone mode)
  else if (firstLine.startsWith("GET /app.js"))            sendFile(client, "/m/app.js",            "application/javascript; charset=utf-8");
  else if (firstLine.startsWith("GET /style.css"))         sendFile(client, "/m/style.css",         "text/css; charset=utf-8");
  else if (firstLine.startsWith("GET /manifest.json"))     sendFile(client, "/m/manifest.json",     "application/json; charset=utf-8");
  else if (firstLine.startsWith("GET /service-worker.js")) sendFile(client, "/m/service-worker.js", "application/javascript; charset=utf-8");
  else if (firstLine.startsWith("GET /apple-touch-icon")) {
    client.println("HTTP/1.1 204 No Content"); client.println("Connection: close"); client.println();
  }
  else if (firstLine.startsWith("GET /favicon.ico")) {
    client.println("HTTP/1.1 204 No Content"); client.println("Connection: close"); client.println();
  }
  else if (firstLine.startsWith("GET /m/")) {
    int sp  = firstLine.indexOf(' ');
    int sp2 = firstLine.indexOf(' ', sp + 1);
    if (sp < 0 || sp2 < 0) {
      client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
    } else {
      String path = firstLine.substring(sp + 1, sp2);
      int q = path.indexOf('?'); if (q >= 0) path = path.substring(0, q);
      if (!path.startsWith("/m/") || path.indexOf("..") >= 0) {
        client.println("HTTP/1.1 400 Bad Request"); client.println("Connection: close"); client.println();
      } else {
        sendFile(client, path.c_str(), guessMimeFromPath(path));
      }
    }
  }
  // ---- API ----
  else if (firstLine.startsWith("GET /relays.txt"))         handleRelaysTxt(client);
  else if (firstLine.startsWith("GET /health"))             handleHealth(client);
  else if (firstLine.startsWith("GET /api/time"))           handleTimeApi(client);
  else if (firstLine.startsWith("GET /api/deviceInfo"))     handleDeviceInfo(client);
  else if (firstLine.startsWith("GET /api/settings"))       handleSettingsApi(client);
  else if (firstLine.startsWith("GET /api/esp2ping"))       handleEsp2PingApi(client);
  else if (firstLine.startsWith("GET /api/esp2telem"))      handleEsp2TelemApi(client);
  else if (firstLine.startsWith("GET /api/relayLog"))       handleRelayLogApi(client);
  else if (firstLine.startsWith("GET /api/tooltips"))       handleTooltipsGet(client);
  else if (firstLine.startsWith("GET /api/users"))          handleUsersListApi(client);
  else if (firstLine.startsWith("POST /api/saveNetwork"))   handleSaveNetwork(client, body);
  else if (firstLine.startsWith("POST /api/saveWifi"))      handleSaveWifi(client, body);
  else if (firstLine.startsWith("POST /api/saveNtp"))       handleSaveNtp(client, body);
  else if (firstLine.startsWith("POST /api/saveCustomer"))  handleSaveCustomer(client, body);
  else if (firstLine.startsWith("POST /api/saveDescriptions")) handleSaveDescriptions(client, body);
  else if (firstLine.startsWith("POST /api/reboot"))        handleReboot(client);
  else if (firstLine.startsWith("POST /api/factoryReset"))  handleFactoryReset(client, body);
  else if (firstLine.startsWith("POST /api/toggleAllPorts")) handleToggleAllPorts(client, body);
  else if (firstLine.startsWith("POST /api/toggleAllRelays")) handleToggleAllRelays(client, body);
  else if (firstLine.startsWith("POST /api/setTimer"))      handleSetTimer(client, body);
  else if (firstLine.startsWith("POST /api/saveTooltips"))  handleTooltipsSave(client, body);
  else if (firstLine.startsWith("POST /save-admin"))        handleSaveAdmin(client, body);
  else if (firstLine.startsWith("POST /api/addUser"))       handleAddUserApi(client, body);
  else if (firstLine.startsWith("POST /api/updateUser"))    handleUpdateUserApi(client, body);
  else if (firstLine.startsWith("POST /api/deleteUser"))    handleDeleteUserApi(client, body);
  else if (firstLine.startsWith("POST /upload-firmware"))   handleFirmwareUpload(client, header, body);
  else if (firstLine.startsWith("POST /api/uploadFirmwareRaw")) handleFirmwareRaw(client, header, body);
  else if (firstLine.startsWith("POST /api/uploadWebFile")) handleUploadWebFile(client, header, body, firstLine);
  else if (firstLine.indexOf("/toggle?") >= 0)              handleToggle(client, firstLine);
  else {
    client.println("HTTP/1.1 404 Not Found");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close"); client.println(); client.println("404");
  }

  delay(5);
  client.stop();
}

// ================================================================
// Users array definitions
// ================================================================
void initUsersArray() {
  for (int i = 0; i < MAX_USERS; i++) {
    users[i] = { "", "", "", "", false };
  }
  primaryAdminIndex = 0;
}

void saveUsersToPrefs() {
  preferences.begin("users", false);
  preferences.putInt("count",   MAX_USERS);
  preferences.putInt("primary", primaryAdminIndex);
  for (int i = 0; i < MAX_USERS; i++) {
    String base = "u" + String(i) + "_";
    preferences.putBool((base + "used").c_str(), users[i].used);
    if (users[i].used) {
      preferences.putString((base + "name").c_str(), users[i].username);
      preferences.putString((base + "pass").c_str(), users[i].password);
      preferences.putString((base + "role").c_str(), users[i].role);
      preferences.putString((base + "last").c_str(), users[i].lastLogin);
    }
  }
  preferences.end();
}

void loadUsersFromPrefs() {
  initUsersArray();
  preferences.begin("users", true);
  int cnt = preferences.getInt("count", 0);
  primaryAdminIndex = preferences.getInt("primary", 0);
  if (cnt == 0) {
    preferences.end();
    users[0] = { getUsername(), getPassword(), "admin", "", true };
    primaryAdminIndex = 0;
    saveUsersToPrefs();
    return;
  }
  for (int i = 0; i < MAX_USERS; i++) {
    String base = "u" + String(i) + "_";
    if (!preferences.getBool((base + "used").c_str(), false)) continue;
    users[i].used      = true;
    users[i].username  = preferences.getString((base + "name").c_str(), "");
    users[i].password  = preferences.getString((base + "pass").c_str(), "");
    users[i].role      = preferences.getString((base + "role").c_str(), "viewer");
    users[i].lastLogin = preferences.getString((base + "last").c_str(), "");
  }
  preferences.end();
}

int findUserIndex(const String& username) {
  for (int i = 0; i < MAX_USERS; i++)
    if (users[i].used && users[i].username == username) return i;
  return -1;
}

int findFreeUserSlot() {
  for (int i = 0; i < MAX_USERS; i++)
    if (!users[i].used) return i;
  return -1;
}

// ================================================================
// setup
// ================================================================
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n[ESP1] Booting V3.1.4-hotfix...");

  // W5500 reset
  pinMode(W5500_RST, OUTPUT);
  digitalWrite(W5500_RST, LOW);  delay(200);
  digitalWrite(W5500_RST, HIGH); delay(200);

  // WDT: 30 ثانیه
  esp_task_wdt_config_t wdt_config = {
    .timeout_ms     = 30000,
    .idle_core_mask = (1 << portNUM_PROCESSORS) - 1,
    .trigger_panic  = true
  };
  esp_task_wdt_init(&wdt_config);
  esp_task_wdt_add(NULL);

  // SIM800 – UART2
  Serial.print("[INIT] SIM800 UART2 RX="); Serial.print(SIM800_RX);
  Serial.print(" TX="); Serial.println(SIM800_TX);
  sim800.begin(9600, SERIAL_8N1, SIM800_RX, SIM800_TX);
  delay(1000);
  sim800.println("AT");         delay(500);
  sim800.println("AT+CMGF=1"); delay(500);  // text mode
  sim800.println("AT+CNMI=1,2,0,0,0"); delay(500);  // دریافت مستقیم SMS
  Serial.println("[INIT] SIM800 ready.");

  // ESP2 serial link – UART1  ← HOTFIX: RX=GPIO26, TX=GPIO25
  Serial.print("[INIT] ESP2 UART1 RX="); Serial.print(ESP2_UART_RX);
  Serial.print(" TX="); Serial.println(ESP2_UART_TX);
  esp2Serial.begin(115200, SERIAL_8N1, ESP2_UART_RX, ESP2_UART_TX);
  esp2Serial.setTimeout(0);
  esp2InitLink();
  Serial.println("[INIT] ESP2 link ready.");

  // I2C + رله‌ها
  Wire.begin(21, 22);
  initRelays();

  // SD
  hspi.begin(14, 4, 13, SD_CS);
  if (SD.begin(SD_CS, hspi)) {
    Serial.println("SD ready");
    ensureRelayLogHeader();
    loadTooltipsFromFile();
  } else {
    Serial.println("SD fail – web files unavailable");
  }

  // Preferences
  loadWifiConfig();
  loadEthConfig();
  loadNtpConfig();
  loadCustomerConfig();
  loadUsersFromPrefs();

  // Ethernet
  ethernetBeginFromConfig();
  Udp.begin(8888);
  Serial.print("[INIT] Ethernet IP: "); Serial.println(Ethernet.localIP());

  // WiFi AP
  WiFi.mode(WIFI_AP);
  WiFi.setSleep(false);
  if (WiFi.softAP(wifiCfg.ssid.c_str(), wifiCfg.pass.c_str())) {
    Serial.print("AP SSID: "); Serial.println(wifiCfg.ssid);
    Serial.print("AP IP:   "); Serial.println(WiFi.softAPIP());
  } else {
    Serial.println("AP start failed!");
  }
  wifiServer.begin();

  // NTP از طریق Ethernet – HOTFIX
  // configTime فقط با WiFi کار می‌کند؛ ما از ntpUdp بر روی Ethernet استفاده می‌کنیم
  configTime(ntpCfg.gmtOffsetSec, ntpCfg.daylightOffsetSec,
             ntpCfg.server1.c_str(), ntpCfg.server2.c_str()); // fallback اگر WiFi Client موجود باشد
  delay(100);
  // تلاش اولیه از طریق Ethernet (non-blocking: اگر نشد در loop تکرار می‌شود)
  syncTimeWithNtpOverEthernet(ntpCfg.server1.c_str());
  if (!timeSynced) Serial.println("[NTP] Initial sync pending – will retry in loop.");

  Serial.print("[INIT] Default admin: "); Serial.println(getUsername());
  Serial.println("[ESP1] Boot complete (V3.1.4-hotfix).");
}

// ================================================================
// loop – غیرمسدود، بدون delay اضافی
// ================================================================
void loop() {
  // --- سرویس HTTP ---
  EthernetClient ethClient = ethServer.available();
  if (ethClient) handleClient(ethClient);

  WiFiClient wifiClient = wifiServer.available();
  if (wifiClient) handleClient(wifiClient);

  // --- پروتکل ESP2 Link (فریم‌های ورودی از ESP2) ---
  {
    Esp2Link::Frame fr;
    while (esp2Link.poll(fr)) {
      if (fr.type == Esp2Link::MSG_PONG) {
        Serial.println("[ESP2] PONG received");
      } else if (fr.type == Esp2Link::MSG_TELEM_RSP) {
        Serial.print("[ESP2] TELEM_RSP len="); Serial.println(fr.len);
      } else if (fr.type == Esp2Link::MSG_ACK) {
        Serial.print("[ESP2] ACK seq="); Serial.println(fr.seq);
      } else if (fr.type == Esp2Link::MSG_NACK) {
        Serial.print("[ESP2] NACK seq="); Serial.println(fr.seq);
      } else if (fr.flags & Esp2Link::FL_ACK_REQ) {
        esp2Link.sendAck(fr.seq);
      }
    }
  }

  // --- تایمر ساده ---
  checkSimpleTimer();

  unsigned long now = millis();

  // --- Heartbeat ---
  if (now - lastHeartbeat > 30000) {
    lastHeartbeat = now;
    Serial.print("Heartbeat to "); Serial.println(hbGateway);
    Udp.beginPacket(hbGateway, 33445);
    Udp.write("hb");
    Udp.endPacket();
  }

  // --- Ethernet link check (یک بار هر 60 ثانیه) – HOTFIX: کاهش تعداد reinit ---
  if (now - lastLinkCheck > 60000) {
    lastLinkCheck = now;
    ethernetReinitIfDown();
  }

  // --- SIM800 SMS – HOTFIX: پارسر خط‌محور از V2.4 ---
  {
    static bool   waitingForSmsText = false;
    static String smsLine           = "";
    static String lastSmsSender     = "";

    while (sim800.available()) {
      char c = sim800.read();
      if (c == '\n') {
        String l = smsLine; smsLine = ""; l.trim();
        if (l.length() == 0) continue;
        Serial.print("[SIM800] "); Serial.println(l);

        if (l.startsWith("+CMT:")) {
          // +CMT: "+989121792668","","26/04/17,00:53:07+14"
          lastSmsSender = "";
          int q1 = l.indexOf('"');
          int q2 = (q1 >= 0) ? l.indexOf('"', q1 + 1) : -1;
          if (q1 >= 0 && q2 > q1) lastSmsSender = normalizePhone(l.substring(q1 + 1, q2));
          waitingForSmsText = true;
          continue;
        }
        if (waitingForSmsText) {
          waitingForSmsText = false;
          Serial.print("[SMS] text="); Serial.println(l);
          processSMS(lastSmsSender, l);  // HOTFIX: ارسال sender به processSMS
          continue;
        }
      } else if (c != '\r') {
        smsLine += c;
        if (smsLine.length() > 200) smsLine.remove(0, 100);
      }
    }
  }

  // --- NTP retry – HOTFIX: از V2.4 ---
  if (!timeSynced && millis() - lastNtpSyncAttemptMs > 15000) {
    lastNtpSyncAttemptMs = millis();
    syncTimeWithNtpOverEthernet(ntpCfg.server1.c_str());
  }
  static unsigned long lastPeriodicNtpSync = 0;
  if (timeSynced && millis() - lastPeriodicNtpSync > 6UL * 3600UL * 1000UL) {
    lastPeriodicNtpSync = millis();
    syncTimeWithNtpOverEthernet(ntpCfg.server1.c_str());
  }

  // --- WDT reset ---
  esp_task_wdt_reset();
  yield();
}
