// ================================================================
// ذخیره/بازیابی وضعیت رله‌ها
// ================================================================
void loadRelayStateFromPrefs() {
  preferences.begin("relays", true);
  String s = preferences.getString("state", "");
  preferences.end();
  if (s.length() == RELAY_CH_COUNT) {
    for (int i = 0; i < RELAY_CH_COUNT; i++) relayState[i] = (s.charAt(i) == '1');
  } else {
    for (int i = 0; i < RELAY_CH_COUNT; i++) relayState[i] = false;
  }
}

void saveRelayStateToPrefs() {
  String s;
  s.reserve(RELAY_CH_COUNT);
  for (int i = 0; i < RELAY_CH_COUNT; i++) s += (relayState[i] ? '1' : '0');
  preferences.begin("relays", false);
  preferences.putString("state", s);
  preferences.end();
}

// ================================================================
// Ethernet
// ================================================================
void ethernetBeginFromConfig() {
  Serial.println("Init Ethernet (from config)...");
  SPI.begin(18, 19, 23, W5500_CS);
  Ethernet.init(W5500_CS);
  if (ethCfg.net.ip_mode == "dhcp") {
    Ethernet.begin(mac);
    Serial.println("Ethernet via DHCP");
  } else {
    Ethernet.begin(mac, ethCfg.net.ip, ethCfg.net.dns, ethCfg.net.gw, ethCfg.net.subnet);
    Serial.print("Ethernet static IP: ");
    Serial.println(ethCfg.net.ip);
  }
  hbGateway = ethCfg.net.gw;
  Serial.print("Heartbeat gateway: ");
  Serial.println(hbGateway);
  Serial.print("Ethernet local IP: ");
  Serial.println(Ethernet.localIP());
  ethServer.begin();
}

void ethernetReinitIfDown() {
  // HOTFIX: بدون reset سخت‌افزاری W5500 – جلوگیری از قطع ناخواسته ارتباط
  auto ls = Ethernet.linkStatus();
  if (ls == LinkON) {
    ethernetOk = true;
  } else if (ls == LinkOFF) {
    Serial.println("ETH LINK DOWN → soft reinit (no H/W reset)");
    ethernetOk = false;
    ethernetBeginFromConfig();
  }
  // ls == Unknown → نادیده می‌گیریم تا reinit مخرب نشود
}

// ================================================================
// رله‌ها
// ================================================================
void writeOutputsToChip(uint8_t addr, int baseChannel) {
  uint8_t port0_active = 0;
  uint8_t port1_active = 0;
  for (int i = 0; i < 8; i++) {
    int ch = baseChannel + i;
    if (ch < RELAY_CH_COUNT && relayState[ch]) port0_active |= (1 << i);
  }
  for (int i = 0; i < 8; i++) {
    int ch = baseChannel + 8 + i;
    if (ch < RELAY_CH_COUNT && relayState[ch]) port1_active |= (1 << i);
  }
  uint8_t port0 = ~port0_active;
  uint8_t port1 = ~port1_active;
  Wire.beginTransmission(addr);
  Wire.write(REG_OUTPUT_PORT0);
  Wire.write(port0);
  Wire.write(port1);
  uint8_t err = Wire.endTransmission();
  Serial.print("PCA addr=0x"); Serial.print(addr, HEX);
  Serial.print(" baseCh=");    Serial.print(baseChannel);
  Serial.print(" I2Cerr=");    Serial.println(err);
}

void applyAllOutputs() {
  writeOutputsToChip(PCA1_ADDR, 0);
  writeOutputsToChip(PCA2_ADDR, 16);
}

void initRelays() {
  p1.begin(); p2.begin();
  for (int i = 0; i < 16; i++) {
    p1.pinMode1(i, OUTPUT);
    p2.pinMode1(i, OUTPUT);
  }
  loadRelayStateFromPrefs();
  applyAllOutputs();
}

String getRelaysStatusString() {
  String s;
  s.reserve(RELAY_CH_COUNT);
  for (int i = 0; i < RELAY_CH_COUNT; i++) s += (relayState[i] ? '1' : '0');
  return s;
}

// ================================================================
// Login / Users
// ================================================================
String getUsername() {
  preferences.begin("auth", true);
  String u = preferences.getString("admin_user", defaultUser);
  preferences.end();
  return u;
}

String getPassword() {
  preferences.begin("auth", true);
  String p = preferences.getString("admin_pass", defaultPass);
  preferences.end();
  return p;
}

void setAdminCredentials(const String& user, const String& pass) {
  preferences.begin("auth", false);
  preferences.putString("admin_user", user);
  preferences.putString("admin_pass", pass);
  preferences.end();
}

// اعلان‌های توابع کاربر (تعریف‌ها در پایین فایل)
void    initUsersArray();
void    saveUsersToPrefs();
void    loadUsersFromPrefs();
int     findUserIndex(const String& username);
int     findFreeUserSlot();

bool isAdmin() {
  if (!isLoggedIn) return false;
  if (currentUser.length() == 0) return true;
  int idx = findUserIndex(currentUser);
  if (idx < 0) return false;
  return (users[idx].role == "admin");
}

// ================================================================
// Tooltip helpers
// ================================================================
void initTooltipArrays() {
  for (int i = 0; i < 24; i++) {
    portTooltips[i].type = 'P'; portTooltips[i].index = i + 1;
    for (int j = 0; j < 5; j++) portTooltips[i].texts[j] = "";
  }
  for (int i = 0; i < 8; i++) {
    relayTooltips[i].type = 'R'; relayTooltips[i].index = i + 1;
    for (int j = 0; j < 5; j++) relayTooltips[i].texts[j] = "";
  }
}

void loadTooltipsFromFile() {
  initTooltipArrays();
  if (!SD.exists("/tooltips.txt")) { Serial.println("tooltips.txt not found"); return; }
  File f = SD.open("/tooltips.txt", FILE_READ);
  if (!f) { Serial.println("Failed to open tooltips.txt"); return; }

  auto parseLine = [](const String& line) {
    if (line.length() == 0) return;
    char type = line.charAt(0);
    int  sep1 = line.indexOf('|');
    if (sep1 <= 1) return;
    int idx = line.substring(1, sep1).toInt();
    if (idx <= 0) return;
    String rest   = line.substring(sep1 + 1);
    String parts[5];
    int pCount = 0, start = 0;
    while (start < (int)rest.length() && pCount < 5) {
      int p = rest.indexOf('|', start);
      if (p < 0) p = rest.length();
      parts[pCount++] = rest.substring(start, p);
      start = p + 1;
    }
    if (type == 'P' && idx >= 1 && idx <= 24) {
      TooltipEntry& e = portTooltips[idx - 1];
      for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
    } else if (type == 'R' && idx >= 1 && idx <= 8) {
      TooltipEntry& e = relayTooltips[idx - 1];
      for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
    }
  };

  String line;
  while (f.available()) {
    char c = f.read();
    if (c == '\n') { line.trim(); parseLine(line); line = ""; }
    else line += c;
  }
  line.trim(); parseLine(line);
  f.close();
  Serial.println("Tooltips loaded.");
}

void saveTooltipsToFile() {
  SD.remove("/tooltips.txt");
  File f = SD.open("/tooltips.txt", FILE_WRITE);
  if (!f) { Serial.println("Failed to open tooltips.txt for write"); return; }
  auto writeEntry = [&f](TooltipEntry* arr, int count, char prefix) {
    for (int i = 0; i < count; i++) {
      TooltipEntry& e = arr[i];
      bool any = false;
      for (int j = 0; j < 5; j++) if (e.texts[j].length()) { any = true; break; }
      if (!any) continue;
      f.print(prefix); f.print(e.index); f.print('|');
      for (int j = 0; j < 5; j++) { if (j > 0) f.print('|'); f.print(e.texts[j]); }
      f.println();
    }
  };
  writeEntry(portTooltips,  24, 'P');
  writeEntry(relayTooltips,  8, 'R');
  f.close();
  Serial.println("Tooltips saved.");
}

// ================================================================
// SD / ارسال فایل
// ================================================================
void sendFile(Stream& client, const char* path, const char* mime) {
  File f = SD.open(path, FILE_READ);
  if (!f) {
    client.println("HTTP/1.1 404 Not Found");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Cache-Control: no-store");
    client.println("Connection: close");
    client.println();
    client.print("File not found: "); client.println(path);
    return;
  }
  client.println("HTTP/1.1 200 OK");
  client.print("Content-Type: "); client.println(mime);
  client.println("Cache-Control: no-store");
  client.println("Connection: close");
  client.println();

  static uint8_t buf[1024];
  while (true) {
    int n = f.read(buf, sizeof(buf));
    if (n <= 0) break;
    client.write(buf, n);
    esp_task_wdt_reset();
    delay(0);
  }
  f.close();
}

const char* guessMimeFromPath(const String& path) {
  if (path.endsWith(".html")) return "text/html; charset=utf-8";
  if (path.endsWith(".css"))  return "text/css; charset=utf-8";
  if (path.endsWith(".js"))   return "application/javascript; charset=utf-8";
  if (path.endsWith(".json")) return "application/json; charset=utf-8";
  if (path.endsWith(".png"))  return "image/png";
  if (path.endsWith(".svg"))  return "image/svg+xml";
  if (path.endsWith(".ico"))  return "image/x-icon";
  return "application/octet-stream";
}

