// ================================================================
// ESP2 Link Protocol (Esp2Link)
// ================================================================
namespace Esp2Link {

static const uint8_t SOF1 = 0xA5;
static const uint8_t SOF2 = 0x5A;
static const uint8_t VER  = 0x01;

enum MsgType : uint8_t {
  MSG_PING      = 0x01,
  MSG_PONG      = 0x02,
  MSG_TELEM_REQ = 0x10,
  MSG_TELEM_RSP = 0x11,
  MSG_ACK       = 0x7E,
  MSG_NACK      = 0x7F,
};

enum Flags : uint8_t {
  FL_ACK_REQ = 0x01,
};

struct Frame {
  uint8_t  ver;
  uint8_t  type;
  uint8_t  seq;
  uint8_t  flags;
  uint16_t len;
  uint8_t  payload[256];
  uint16_t crc;
};

// CRC16-CCITT-FALSE (poly 0x1021, init 0xFFFF)
static uint16_t crc16_ccitt_false(const uint8_t* data, size_t len) {
  uint16_t crc = 0xFFFF;
  for (size_t i = 0; i < len; i++) {
    crc ^= (uint16_t)data[i] << 8;
    for (int b = 0; b < 8; b++) {
      crc = (crc & 0x8000) ? (crc << 1) ^ 0x1021 : crc << 1;
    }
  }
  return crc;
}

static void writeU16LE(Stream& s, uint16_t v) {
  s.write((uint8_t)(v & 0xFF));
  s.write((uint8_t)((v >> 8) & 0xFF));
}

static uint16_t readU16LE(const uint8_t* p) {
  return (uint16_t)p[0] | ((uint16_t)p[1] << 8);
}

class Link {
public:
  explicit Link(Stream& io) : _io(io) {}

  void begin() {
    _seqTx    = 0;
    _lastRxMs = millis();
  }

  // در loop() فراخوانی شود
  bool poll(Frame& out) {
    while (_io.available()) {
      int b = _io.read();
      if (b < 0) break;
      if (_parseByte((uint8_t)b, out)) {
        _lastRxMs = millis();
        return true;
      }
    }
    return false;
  }

  // ارسال فریم (بدون انتظار)
  void send(uint8_t type, const uint8_t* payload, uint16_t len,
            uint8_t flags = 0, uint8_t seqOverride = 0xFF) {
    uint8_t seq = (seqOverride == 0xFF) ? _seqTx++ : seqOverride;

    uint8_t hdr[8];
    hdr[0] = SOF1;  hdr[1] = SOF2;
    hdr[2] = VER;   hdr[3] = type;
    hdr[4] = seq;   hdr[5] = flags;
    hdr[6] = (uint8_t)(len & 0xFF);
    hdr[7] = (uint8_t)((len >> 8) & 0xFF);

    uint8_t crcBuf[6 + 256];
    crcBuf[0] = hdr[2]; crcBuf[1] = hdr[3];
    crcBuf[2] = hdr[4]; crcBuf[3] = hdr[5];
    crcBuf[4] = hdr[6]; crcBuf[5] = hdr[7];
    for (uint16_t i = 0; i < len && i < 256; i++) crcBuf[6 + i] = payload[i];

    uint16_t crc = crc16_ccitt_false(crcBuf, 6 + len);

    _io.write(hdr, 8);
    if (len) _io.write(payload, len);
    writeU16LE(_io, crc);
  }

  // ارسال و انتظار برای ACK/NACK
  bool sendWithAck(uint8_t type, const uint8_t* payload, uint16_t len,
                   uint32_t timeoutMs = 300, int retries = 3) {
    for (int attempt = 0; attempt < retries; attempt++) {
      send(type, payload, len, FL_ACK_REQ, 0xFF);
      uint8_t sentSeq = (uint8_t)(_seqTx - 1);

      uint32_t t0 = millis();
      while (millis() - t0 < timeoutMs) {
        Frame fr;
        if (poll(fr)) {
          if (fr.flags & FL_ACK_REQ) sendAck(fr.seq);
          if (fr.type == MSG_ACK  && fr.seq == sentSeq) return true;
          if (fr.type == MSG_NACK && fr.seq == sentSeq) break;
        }
        delay(1);
      }
    }
    return false;
  }

  void sendAck(uint8_t seq)  { send(MSG_ACK,  nullptr, 0, 0, seq); }
  void sendNack(uint8_t seq) { send(MSG_NACK, nullptr, 0, 0, seq); }

  uint32_t lastRxAgeMs() const { return millis() - _lastRxMs; }

private:
  Stream&  _io;
  uint8_t  _seqTx   = 0;
  uint32_t _lastRxMs = 0;

  uint8_t  _st = 0;
  uint8_t  _hdr[6];
  uint16_t _need = 0;
  uint16_t _pos  = 0;
  uint8_t  _payload[256];
  uint8_t  _crcBytes[2];

  bool _parseByte(uint8_t b, Frame& out) {
    switch (_st) {
      case 0:
        if (b == SOF1) _st = 1;
        return false;
      case 1:
        if (b == SOF2) { _st = 2; _pos = 0; }
        else _st = 0;
        return false;
      case 2:
        _hdr[_pos++] = b;
        if (_pos == 6) {
          if (_hdr[0] != VER) { _st = 0; return false; }
          _need = readU16LE(&_hdr[4]);
          if (_need > 256)  { _st = 0; return false; }
          _pos = 0;
          _st = (_need > 0) ? 3 : 4;
        }
        return false;
      case 3:
        _payload[_pos++] = b;
        if (_pos == _need) { _pos = 0; _st = 4; }
        return false;
      case 4:
        _crcBytes[_pos++] = b;
        if (_pos == 2) {
          uint16_t rxCrc = readU16LE(_crcBytes);
          uint8_t  crcBuf[6 + 256];
          for (int i = 0; i < 6; i++) crcBuf[i] = _hdr[i];
          for (uint16_t i = 0; i < _need; i++) crcBuf[6 + i] = _payload[i];
          uint16_t calc = crc16_ccitt_false(crcBuf, 6 + _need);
          _st = 0;
          if (calc != rxCrc) return false;
          out.ver   = _hdr[0]; out.type  = _hdr[1];
          out.seq   = _hdr[2]; out.flags = _hdr[3];
          out.len   = _need;
          for (uint16_t i = 0; i < _need; i++) out.payload[i] = _payload[i];
          out.crc   = rxCrc;
          return true;
        }
        return false;
      default:
        _st = 0;
        return false;
    }
  }
};

} // namespace Esp2Link

// ================================================================
// اشیاء سریال ESP2 (تعریف واقعی)
// ================================================================
HardwareSerial    esp2Serial(1);
Esp2Link::Link    esp2Link(esp2Serial);

void esp2InitLink() {
  esp2Link.begin();
}

// ================================================================
// کمک‌کننده‌های IP / Pref
// ================================================================
uint32_t  ipToUint(IPAddress ip) { return (uint32_t)ip; }
IPAddress uintToIp(uint32_t v)   { return IPAddress(v); }

// ---------- WiFi Config ----------
void loadWifiConfig() {
  preferences.begin("wifi", true);
  wifiCfg.ssid = preferences.getString("ssid", AP_SSID_DEFAULT);
  wifiCfg.pass = preferences.getString("pass", AP_PASS_DEFAULT);
  wifiCfg.net.ip_mode = preferences.getString("ip_mode", "dhcp");
  uint32_t ipv     = preferences.getULong("ip",     (uint32_t)ipDefault);
  uint32_t subnetv = preferences.getULong("subnet", (uint32_t)subnetDefault);
  uint32_t gwv     = preferences.getULong("gw",     (uint32_t)gwDefault);
  uint32_t dnsv    = preferences.getULong("dns",    (uint32_t)dnsDefault);
  preferences.end();
  wifiCfg.net.ip     = uintToIp(ipv);
  wifiCfg.net.subnet = uintToIp(subnetv);
  wifiCfg.net.gw     = uintToIp(gwv);
  wifiCfg.net.dns    = uintToIp(dnsv);
}

void saveWifiConfig(const WifiConfig& cfg) {
  preferences.begin("wifi", false);
  preferences.putString("ssid",    cfg.ssid);
  preferences.putString("pass",    cfg.pass);
  preferences.putString("ip_mode", cfg.net.ip_mode);
  preferences.putULong("ip",     ipToUint(cfg.net.ip));
  preferences.putULong("subnet", ipToUint(cfg.net.subnet));
  preferences.putULong("gw",     ipToUint(cfg.net.gw));
  preferences.putULong("dns",    ipToUint(cfg.net.dns));
  preferences.end();
}

// ---------- ETH Config ----------
void loadEthConfig() {
  preferences.begin("eth", true);
  ethCfg.net.ip_mode = preferences.getString("ip_mode", "static");
  uint32_t ipv     = preferences.getULong("ip",     (uint32_t)ipDefault);
  uint32_t subnetv = preferences.getULong("subnet", (uint32_t)subnetDefault);
  uint32_t gwv     = preferences.getULong("gw",     (uint32_t)gwDefault);
  uint32_t dnsv    = preferences.getULong("dns",    (uint32_t)dnsDefault);
  preferences.end();
  ethCfg.net.ip     = uintToIp(ipv);
  ethCfg.net.subnet = uintToIp(subnetv);
  ethCfg.net.gw     = uintToIp(gwv);
  ethCfg.net.dns    = uintToIp(dnsv);
}

void saveEthConfig(const EthConfig& cfg) {
  preferences.begin("eth", false);
  preferences.putString("ip_mode", cfg.net.ip_mode);
  preferences.putULong("ip",     ipToUint(cfg.net.ip));
  preferences.putULong("subnet", ipToUint(cfg.net.subnet));
  preferences.putULong("gw",     ipToUint(cfg.net.gw));
  preferences.putULong("dns",    ipToUint(cfg.net.dns));
  preferences.end();
}

