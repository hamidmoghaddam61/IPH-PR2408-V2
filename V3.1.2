// ---------------- Charger APIs ----------------
void handleChargerGet(Stream &client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.println("ERROR:Forbidden");
    return;
  }

  bool ok = getEsp2Ok();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: application/json; charset=utf-8");
  client.println("Cache-Control: no-store");
  client.println("Connection: close");
  client.println();
  client.print("{\"enabled\":");
  client.print(chargerEnabled ? "true" : "false");
  client.print(",\"esp2_ok\":");
  client.print(ok ? "true" : "false");
  client.println("}");
}

void handleChargerPost(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  String val = getField(body, "enabled");
  bool newState;

  if (val == "1" || val == "on" || val == "true") {
    newState = true;
  } else if (val == "0" || val == "off" || val == "false") {
    newState = false;
  } else {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:مقدار enabled نامعتبر است. باید 1|0|on|off باشد.");
    return;
  }

  chargerEnabled = newState;
  saveChargerConfig();
  applyChargerGpio();

  Serial.print("[Charger] enabled=");
  Serial.println(chargerEnabled ? "true" : "false");

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print(chargerEnabled ? "OK:شارژر فعال شد." : "OK:شارژر غیرفعال شد.");
}

// ---------------- ESP2 Test APIs ----------------
void handleEsp2PingApi(Stream &client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.println("ERROR:Forbidden");
    return;
  }

  bool ok = esp2Link.sendWithAck(Esp2Link::MSG_PING, nullptr, 0, 150, 3);

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.println(ok ? "OK:PONG" : "ERROR:TIMEOUT");
}

void handleEsp2TelemApi(Stream &client) {
  if (!isLoggedIn) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.println("ERROR:Forbidden");
    return;
  }

  // فعلاً درخواست تله‌متری بدون payload (بعداً می‌تونیم پارامترها را مشخص کنیم)
  bool ok = esp2Link.sendWithAck(Esp2Link::MSG_TELEM_REQ, nullptr, 0, 200, 3);

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();

  if (!ok) {
    client.println("ERROR:TIMEOUT");
    return;
  }

  // اگر ESP2 جواب TELEM_RSP را بعدش بفرستد، در loop با poll می‌گیریم.
  // برای مرحله اول فقط اعلام می‌کنیم که درخواست ارسال شد.
  client.println("OK:TELEM_REQ_SENT");
}


void loop() {
  EthernetClient ethClient = ethServer.available();
  if (ethClient) handleClient(ethClient);

  WiFiClient wifiClient = wifiServer.available();
  if (wifiClient) handleClient(wifiClient);

  unsigned long now = millis();

  if (now - lastHeartbeat > 30000) {
    lastHeartbeat = now;
    Serial.print("Heartbeat to ");
    Serial.println(hbGateway);
    Udp.beginPacket(hbGateway, 33445);
    Udp.write("hb");
    Udp.endPacket();
  }

  if (now - lastLinkCheck > 10000) {
    lastLinkCheck = now;
    ethernetReinitIfDown();
  }
if (millis() - lastLinkCheck > 5000) {
  lastLinkCheck = millis();

  if (Ethernet.linkStatus() == LinkOFF) {
    Serial.println("ETH LINK DOWN → RESET W5500");

    digitalWrite(W5500_RST, LOW);
    delay(200);
    digitalWrite(W5500_RST, HIGH);
    delay(500);

    Ethernet.begin(mac, ipDefault, dnsDefault, gwDefault, subnetDefault);
  }
}
  esp_task_wdt_reset();

  while (sim800.available()) {
    char c = sim800.read();
    smsBuffer += c;

    if (smsBuffer.indexOf("+CMT:") != -1) {
      smsIncoming = true;
    }

    // پایان پیام
    if (smsIncoming && smsBuffer.endsWith("\r\n\r\n")) {

      Serial.println("RAW SMS:");
      Serial.println(smsBuffer);

      processSMS(smsBuffer);

      smsBuffer = "";
      smsIncoming = false;
    }
  }
  {
  // ارسال دوره‌ای PING به ESP2 (هر 3 ثانیه) برای پایش اتصال
  if (now - lastEsp2PingMs > 3000UL) {
    lastEsp2PingMs = now;
    esp2Link.send(Esp2Link::MSG_PING, nullptr, 0);
  }

  Esp2Link::Frame fr;
  while (esp2Link.poll(fr)) {
    if (fr.type == Esp2Link::MSG_PONG) {
      lastPongMs = millis();   // ثبت زمان دریافت PONG
      Serial.println("[ESP2] PONG received");
    } else if (fr.type == Esp2Link::MSG_TELEM_RSP) {
      lastPongMs = millis();   // TELEM_RSP هم به عنوان نشانه اتصال حساب می‌شود
      Serial.print("[ESP2] TELEM_RSP len=");
      Serial.println(fr.len);
    }
  }
}
}
