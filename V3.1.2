void handleUsersListApi(Stream &client) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  loadUsersFromPrefs();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: application/json; charset=utf-8");
  client.println("Connection: close");
  client.println();

  client.print("[");
  bool first = true;
  for (int i = 0; i < MAX_USERS; i++) {
    if (!users[i].used) continue;
    if (!first) client.print(",");
    first = false;

    client.print("{\"username\":\"");
    String u = users[i].username;
    u.replace("\\", "\\\\");
    u.replace("\"", "\\\"");
    client.print(u);
    client.print("\",\"role\":\"");
    client.print(users[i].role);
    client.print("\",\"lastLogin\":\"");
    String l = users[i].lastLogin;
    l.replace("\\", "\\\\");
    l.replace("\"", "\\\"");
    client.print(l);
    client.print("\",\"primary\":");
    client.print(i == primaryAdminIndex ? "true" : "false");
    client.print("}");
  }
  client.print("]");
}

void handleAddUserApi(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  loadUsersFromPrefs();

  String user = getField(body, "user");
  String pass = getField(body, "pass");
  String role = getField(body, "role");
  if (role != "admin" && role != "viewer") role = "viewer";

  if (user.length() == 0 || pass.length() == 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:نام کاربری و رمز عبور الزامی است.");
    return;
  }

  if (findUserIndex(user) >= 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:این نام کاربری قبلا�� ثبت شده است.");
    return;
  }

  int slot = findFreeUserSlot();
  if (slot < 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:حداکثر تعداد کاربران (10) پر شده است.");
    return;
  }

  users[slot].username  = user;
  users[slot].password  = pass;
  users[slot].role      = role;
  users[slot].lastLogin = "";
  users[slot].used      = true;

  saveUsersToPrefs();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:کاربر جدید اضافه شد.");
}

void handleUpdateUserApi(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  loadUsersFromPrefs();

  String oldUser = getField(body, "oldUser");
  String newUser = getField(body, "user");
  String pass    = getField(body, "pass");
  String role    = getField(body, "role");
  if (role != "admin" && role != "viewer") role = "viewer";

  int idx = findUserIndex(oldUser);
  if (idx < 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:کاربر پیدا نشد.");
    return;
  }

  if (newUser != oldUser && findUserIndex(newUser) >= 0) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:نام کاربری جدید تکراری است.");
    return;
  }

  if (newUser.length() == 0) newUser = oldUser;
  if (pass.length() == 0)   pass    = users[idx].password;

  users[idx].username = newUser;
  users[idx].password = pass;
  users[idx].role     = role;

  if (idx == primaryAdminIndex && role != "admin") {
    users[idx].role = "admin";
  }

  saveUsersToPrefs();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:کاربر به‌روزرسانی شد.");
}

