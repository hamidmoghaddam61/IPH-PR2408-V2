// ---------------------------------------------------------------------
// Timer API
// ---------------------------------------------------------------------
void handleSetTimer(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  String targetStr = getField(body, "target");    // "P1".."P24" یا "R1".."R8"
  String firstStr  = getField(body, "first");     // "on" / "off"
  String durStr    = getField(body, "duration");  // ثانیه
  String secondStr = getField(body, "second");    // "on" / "off"

  if (targetStr.length() < 2) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:هدف نامعتبر است");
    return;
  }

  char tType = targetStr.charAt(0); // 'P' یا 'R'
  int index  = targetStr.substring(1).toInt(); // 1..24 یا 1..8
  int ch = -1;

  if (tType == 'P') {
    if (index < 1 || index > 24) {
      client.println("HTTP/1.1 400 Bad Request");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:شماره پورت نامعتبر است");
      return;
    }
    ch = index - 1;
  } else if (tType == 'R') {
    if (index < 1 || index > 8) {
      client.println("HTTP/1.1 400 Bad Request");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:شماره رله نامعتبر است");
      return;
    }
    ch = 24 + (index - 1);
  } else {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:هدف نامعتبر است");
    return;
  }

  unsigned long sec = durStr.toInt();
  if (sec == 0) sec = 1;

  simpleTimer.active      = true;
  simpleTimer.channel     = ch;
  simpleTimer.firstState  = (firstStr  == "on");
  simpleTimer.secondState = (secondStr == "on");
  simpleTimer.startMs     = millis();
  simpleTimer.delayMs     = sec * 1000UL;

  relayState[ch] = simpleTimer.firstState;
  applyAllOutputs();
  saveRelayStateToPrefs();
  appendRelayLog("timer_first", ch);

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:Timer set.");
}

void checkSimpleTimer() {
  if (!simpleTimer.active) return;
  unsigned long now = millis();
  if ((now - simpleTimer.startMs) >= simpleTimer.delayMs) {
    relayState[simpleTimer.channel] = simpleTimer.secondState;
    applyAllOutputs();
    saveRelayStateToPrefs();
    appendRelayLog("timer_second", simpleTimer.channel);
    simpleTimer.active = false;
  }
}

