// ---------------------------------------------------------------------
void loadRelayStateFromPrefs() {
  preferences.begin("relays", true);
  String s = preferences.getString("state", "");
  preferences.end();
  if (s.length() == RELAY_CH_COUNT) {
    for (int i = 0; i < RELAY_CH_COUNT; i++) {
      relayState[i] = (s.charAt(i) == '1');
    }
  } else {
    for (int i = 0; i < RELAY_CH_COUNT; i++) relayState[i] = false;
  }
}

void saveRelayStateToPrefs() {
  String s;
  s.reserve(RELAY_CH_COUNT);
  for (int i = 0; i < RELAY_CH_COUNT; i++) {
    s += (relayState[i] ? '1' : '0');
  }
  preferences.begin("relays", false);
  preferences.putString("state", s);
  preferences.end();
}

// ---------------------------------------------------------------------
// Ethernet init / link-check
// ---------------------------------------------------------------------
void ethernetBeginFromConfig() {
  Serial.println("Init Ethernet (from config)...");
  SPI.begin(18, 19, 23, W5500_CS);
  Ethernet.init(W5500_CS);

  if (ethCfg.net.ip_mode == "dhcp") {
    Ethernet.begin(mac);
    Serial.println("Ethernet via DHCP");
  } else {
    Ethernet.begin(mac,
                   ethCfg.net.ip,
                   ethCfg.net.dns,
                   ethCfg.net.gw,
                   ethCfg.net.subnet);
    Serial.print("Ethernet static IP: ");
    Serial.println(ethCfg.net.ip);
  }

  hbGateway = ethCfg.net.gw;
  Serial.print("Heartbeat gateway: ");
  Serial.println(hbGateway);

  Serial.print("Ethernet local IP: ");
  Serial.println(Ethernet.localIP());

  ethServer.begin();
}

void ethernetReinitIfDown() {
  auto ls = Ethernet.linkStatus();
  Serial.print("Ethernet link status: ");
  if (ls == LinkON) {
    Serial.println("ON");
    ethernetOk = true;
  } else if (ls == LinkOFF) {
    Serial.println("OFF -> re-init");
    ethernetOk = false;
    ethernetBeginFromConfig();
  } else {
    Serial.println("UNKNOWN");
  }
}

// ---------------------------------------------------------------------
// رله‌ها
// ---------------------------------------------------------------------
void writeOutputsToChip(uint8_t addr, int baseChannel) {
  uint8_t port0_active = 0;
  uint8_t port1_active = 0;

  for (int i = 0; i < 8; i++) {
    int ch = baseChannel + i;
    if (ch < RELAY_CH_COUNT && relayState[ch]) {
      port0_active |= (1 << i);
    }
  }
  for (int i = 0; i < 8; i++) {
    int ch = baseChannel + 8 + i;
    if (ch < RELAY_CH_COUNT && relayState[ch]) {
      port1_active |= (1 << i);
    }
  }

  uint8_t port0 = ~port0_active;
  uint8_t port1 = ~port1_active;

  Wire.beginTransmission(addr);
  Wire.write(REG_OUTPUT_PORT0);
  Wire.write(port0);
  Wire.write(port1);
  uint8_t err = Wire.endTransmission();

  Serial.print("PCA addr=0x");
  Serial.print(addr, HEX);
  Serial.print(" baseCh=");
  Serial.print(baseChannel);
  Serial.print(" active0=0b");
  Serial.print(port0_active, BIN);
  Serial.print(" active1=0b");
  Serial.print(port1_active, BIN);
  Serial.print(" OUT0=0b");
  Serial.print(port0, BIN);
  Serial.print(" OUT1=0b");
  Serial.print(port1, BIN);
  Serial.print(" I2Cerr=");
  Serial.println(err);
}

void applyAllOutputs() {
  writeOutputsToChip(PCA1_ADDR, 0);   // ch 0..15
  writeOutputsToChip(PCA2_ADDR, 16);  // ch 16..31
}

void initRelays() {
  p1.begin();
  p2.begin();
  for (int i = 0; i < 16; i++) {
    p1.pinMode1(i, OUTPUT);
    p2.pinMode1(i, OUTPUT);
  }

  loadRelayStateFromPrefs();
  applyAllOutputs();
}

String getRelaysStatusString() {
  String s;
  s.reserve(RELAY_CH_COUNT);
  for (int i = 0; i < RELAY_CH_COUNT; i++) {
    s += (relayState[i] ? '1' : '0');
  }
  return s;
}

