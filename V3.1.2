void handleSaveNtp(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  NtpConfig cfg = ntpCfg;

  String s1   = getField(body, "ntp1");
  String s2   = getField(body, "ntp2");
  String gmt  = getField(body, "gmtOffset");
  String dst  = getField(body, "dstOffset");

  if (s1.length()) cfg.server1 = s1;
  if (s2.length()) cfg.server2 = s2;

  if (gmt.length()) {
    long g = gmt.toInt();
    cfg.gmtOffsetSec = g * 3600;
  }
  if (dst.length()) {
    long d = dst.toInt();
    cfg.daylightOffsetSec = d * 3600;
  }

  saveNtpConfig(cfg);
  ntpCfg = cfg;

  configTime(ntpCfg.gmtOffsetSec, ntpCfg.daylightOffsetSec,
             ntpCfg.server1.c_str(), ntpCfg.server2.c_str());

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:NTP saved & applied.");
}

