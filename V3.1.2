// ---------------------------------------------------------------------
// helpers
// ---------------------------------------------------------------------
// URL-decode field from x-www-form-urlencoded body
String getField(const String &body, const String &name) {
  String key = name + "=";
  int pos = body.indexOf(key);
  if (pos < 0) return "";
  int end = body.indexOf('&', pos);
  if (end < 0) end = body.length();
  String val = body.substring(pos + key.length(), end);

  // + -> space
  val.replace('+', ' ');

  // %XX -> char
  String out;
  out.reserve(val.length());
  for (int i = 0; i < val.length(); i++) {
    char c = val[i];
    if (c == '%' && i + 2 < val.length()) {
      char h1 = val[i+1];
      char h2 = val[i+2];
      int hi = (h1 >= '0' && h1 <= '9') ? (h1 - '0') :
               (h1 >= 'A' && h1 <= 'F') ? (h1 - 'A' + 10) :
               (h1 >= 'a' && h1 <= 'f') ? (h1 - 'a' + 10) : -1;
      int lo = (h2 >= '0' && h2 <= '9') ? (h2 - '0') :
               (h2 >= 'A' && h2 <= 'F') ? (h2 - 'A' + 10) :
               (h2 >= 'a' && h2 <= 'f') ? (h2 - 'a' + 10) : -1;
      if (hi >= 0 && lo >= 0) {
        out += char((hi << 4) | lo);
        i += 2;
      } else {
        // اگر مشکلی بود، همان رشته را نگه می‌داریم
        out += c;
      }
    } else {
      out += c;
    }
  }
  return out;
}
