// Toggle تکی
// ---------------------------------------------------------------------
void handleToggle(Stream &client, const String &firstLine) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:فقط ادمین می‌تواند وضعیت پورت‌ها را تغییر دهد.");
    return;
  }

  int chPos = firstLine.indexOf("ch=");
  if (chPos < 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    return;
  }
  int endPos = firstLine.indexOf(' ', chPos);
  if (endPos < 0) endPos = firstLine.length();
  String chStr = firstLine.substring(chPos + 3, endPos);
  int ch = chStr.toInt();
  if (ch < 0 || ch >= RELAY_CH_COUNT) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    return;
  }

  toggleRelay(ch);

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK");
}


// ---------------------------------------------------------------------
// Router
// ---------------------------------------------------------------------
template<typename ClientType>
void handleClient(ClientType &client) {
  if (!client) return;

  String header, body;
  header.reserve(2048);   // مهم: جلوگیری از تکه‌تکه شدن heap
  body.reserve(1024);

  bool headerEnded = false;
  unsigned long start = millis();

  const uint32_t READ_TIMEOUT_MS = 2000;
  const size_t MAX_HEADER = 4096;   // برای جلوگیری از overflow/heap kill در iOS
  const size_t MAX_BODY   = 4096;

  while (client.connected() && (millis() - start < READ_TIMEOUT_MS)) {
    while (client.available()) {
      char c = (char)client.read();

      if (!headerEnded) {
        if (header.length() < MAX_HEADER) header += c;
        if (header.endsWith("\r\n\r\n")) headerEnded = true;
      } else {
        if (body.length() < MAX_BODY) body += c;
      }
    }

    if (headerEnded) break;

    esp_task_wdt_reset();
    delay(0); // از yield بهتر/شفاف‌تر برای فید دادن به RTOS
  }

  if (!headerEnded) {
    // درخواست ناقص؛ سریع ببند تا گیر نکند
    client.stop();
    return;
  }

  int lineEnd = header.indexOf("\r\n");
  String firstLine = (lineEnd > 0) ? header.substring(0, lineEnd) : header;

  if (firstLine.startsWith("GET / ") || firstLine.startsWith("GET /login "))
    handleLoginPage(client);
  else if (firstLine.startsWith("POST /login"))
    handleLoginPost(client, body);
  else if (firstLine.startsWith("POST /forgot"))
    handleForgot(client, body);
  else if (firstLine.startsWith("GET /logout"))
    handleLogout(client);
  else if (firstLine.startsWith("GET /dashboard"))
    handleDashboard(client);
  else if (firstLine.startsWith("GET /settings"))
    handleSettingsPage(client);
  else if (firstLine.startsWith("GET /log"))
    handleLogPage(client);
  else if (firstLine.startsWith("GET /timer"))
    handleTimerPage(client);
  else if (firstLine.startsWith("GET /tooltip"))
    handleTooltipPage(client);
  else if (firstLine.startsWith("GET /css/style.css"))
    sendFile(client, "/css/style.css", "text/css; charset=utf-8");
  else if (firstLine.startsWith("GET /img/")) {
    if (firstLine.indexOf(".png") >= 0) {
      int sp  = firstLine.indexOf("GET ");
      int sp2 = firstLine.indexOf(" ", sp + 4);
      String path = firstLine.substring(sp + 4, sp2);
      sendFile(client, path.c_str(), "image/png");
    } else {
      client.println("HTTP/1.1 415 Unsupported Media Type");
      client.println("Connection: close");
      client.println();
    }
  }
    // ---------------- PWA Mobile App (/m) ----------------
  else if (firstLine.startsWith("GET /m ") ||
           firstLine.startsWith("GET /m/ ") ||
           firstLine.startsWith("GET /m?")) {
    sendFile(client, "/m/index.html", "text/html; charset=utf-8");
  }
      // ---- PWA aliases for iOS standalone ----
else if (firstLine.startsWith("GET /app.js"))            
sendFile(client, "/m/app.js", "application/javascript; charset=utf-8");
else if (firstLine.startsWith("GET /style.css"))         
sendFile(client, "/m/style.css", "text/css; charset=utf-8");
else if (firstLine.startsWith("GET /manifest.json"))     
sendFile(client, "/m/manifest.json", "application/json; charset=utf-8");
else if (firstLine.startsWith("GET /service-worker.js")) 
sendFile(client, "/m/service-worker.js", "application/javascript; charset=utf-8");

// iOS extra icon requests
else if (firstLine.startsWith("GET /apple-touch-icon")) {
  // اگر فایلش را داری می‌تونی sendFile کنی، اگر نه 204 بده
  client.println("HTTP/1.1 204 No Content");
  client.println("Connection: close");
  client.println();
}
else if (firstLine.startsWith("GET /favicon.ico")) {
  client.println("HTTP/1.1 204 No Content");
  client.println("Connection: close");
  client.println();
}
  else if (firstLine.startsWith("GET /m/")) {

    // Extract raw path from "GET <path> HTTP/1.1"
    int sp  = firstLine.indexOf(' ');
    int sp2 = firstLine.indexOf(' ', sp + 1);
    if (sp < 0 || sp2 < 0) {
      client.println("HTTP/1.1 400 Bad Request");
      client.println("Connection: close");
      client.println();
    } else {
      String path = firstLine.substring(sp + 1, sp2); // e.g. "/m/app.js" or "/m/app.js?x=1"

      // Strip query string if any
      int q = path.indexOf('?');
      if (q >= 0) path = path.substring(0, q);

      // Basic safety
      if (!path.startsWith("/m/") || path.indexOf("..") >= 0) {
        client.println("HTTP/1.1 400 Bad Request");
        client.println("Connection: close");
        client.println();
      } else {
        const char* mime = guessMimeFromPath(path);
        sendFile(client, path.c_str(), mime);
      }
    }
  }

  else if (firstLine.startsWith("GET /relays.txt"))
    handleRelaysTxt(client);
  else if (firstLine.startsWith("GET /health"))
    handleHealth(client);
  else if (firstLine.startsWith("GET /api/time"))
    handleTimeApi(client);
  else if (firstLine.startsWith("GET /api/deviceInfo"))
    handleDeviceInfo(client);
  else if (firstLine.startsWith("GET /api/settings"))
    handleSettingsApi(client);
    else if (firstLine.startsWith("GET /api/charger"))
    handleChargerGet(client);
  else if (firstLine.startsWith("POST /api/charger"))
    handleChargerPost(client, body);
    else if (firstLine.startsWith("GET /api/esp2ping"))
    handleEsp2PingApi(client);
  else if (firstLine.startsWith("GET /api/esp2telem"))
    handleEsp2TelemApi(client);
  else if (firstLine.startsWith("GET /api/relayLog"))
    handleRelayLogApi(client);
  else if (firstLine.startsWith("GET /api/tooltips"))
    handleTooltipsGet(client);
  else if (firstLine.startsWith("GET /api/users"))
    handleUsersListApi(client);
  else if (firstLine.startsWith("POST /api/saveNetwork"))
    handleSaveNetwork(client, body);
  else if (firstLine.startsWith("POST /api/saveWifi"))
    handleSaveWifi(client, body);
  else if (firstLine.startsWith("POST /api/saveNtp"))
    handleSaveNtp(client, body);
  else if (firstLine.startsWith("POST /api/saveCustomer"))
    handleSaveCustomer(client, body);
  else if (firstLine.startsWith("POST /api/saveDescriptions"))
    handleSaveDescriptions(client, body);
  else if (firstLine.startsWith("POST /api/reboot"))
    handleReboot(client);
  else if (firstLine.startsWith("POST /api/factoryReset"))
    handleFactoryReset(client, body);
  else if (firstLine.startsWith("POST /api/toggleAllPorts"))
    handleToggleAllPorts(client, body);
  else if (firstLine.startsWith("POST /api/toggleAllRelays"))
    handleToggleAllRelays(client, body);
  else if (firstLine.startsWith("POST /api/setTimer"))
    handleSetTimer(client, body);
  else if (firstLine.startsWith("POST /api/saveTooltips"))
    handleTooltipsSave(client, body);
  else if (firstLine.startsWith("POST /save-admin"))
    handleSaveAdmin(client, body);
  else if (firstLine.startsWith("POST /api/addUser"))
    handleAddUserApi(client, body);
  else if (firstLine.startsWith("POST /api/updateUser"))
    handleUpdateUserApi(client, body);
  else if (firstLine.startsWith("POST /api/deleteUser"))
    handleDeleteUserApi(client, body);
  else if (firstLine.startsWith("POST /upload-firmware"))
    handleFirmwareUpload(client, header, body);
  else if (firstLine.indexOf("/toggle?") >= 0)
    handleToggle(client, firstLine);
  else if (firstLine.startsWith("POST /api/uploadFirmwareRaw"))
  handleFirmwareRaw(client, header, body);
  else if (firstLine.startsWith("POST /api/uploadWebFile"))
    handleUploadWebFile(client, header, body, firstLine);
  // iOS/Safari extra requests
else if (firstLine.startsWith("GET /favicon.ico")) {
  client.println("HTTP/1.1 204 No Content");
  client.println("Connection: close");
  client.println();
}
else if (firstLine.startsWith("GET /apple-touch-icon") ||
         firstLine.startsWith("GET /apple-touch-icon-precomposed")) {
  // اگر آیکن نداری، 204 بده که هی تلاش نکند
  client.println("HTTP/1.1 204 No Content");
  client.println("Connection: close");
  client.println();
}
else if (firstLine.startsWith("GET /app.js"))            sendFile(client, "/m/app.js", "application/javascript; charset=utf-8");
else if (firstLine.startsWith("GET /style.css"))         sendFile(client, "/m/style.css", "text/css; charset=utf-8");
else if (firstLine.startsWith("GET /manifest.json"))     sendFile(client, "/m/manifest.json", "application/json; charset=utf-8");
else if (firstLine.startsWith("GET /service-worker.js")) sendFile(client, "/m/service-worker.js", "application/javascript; charset=utf-8");
  else {
    client.println("HTTP/1.1 404 Not Found");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.println("404");
  }

  delay(5);
  client.stop();
}

// ---------------------------------------------------------------------
// Users array definitions
// ---------------------------------------------------------------------
void initUsersArray() {
  for (int i = 0; i < MAX_USERS; i++) {
    users[i].username = "";
    users[i].password = "";
    users[i].role     = "";
    users[i].lastLogin= "";
    users[i].used     = false;
  }
  primaryAdminIndex = 0;
}

void saveUsersToPrefs() {
  preferences.begin("users", false);
  preferences.putInt("count", MAX_USERS);
  preferences.putInt("primary", primaryAdminIndex);

  for (int i = 0; i < MAX_USERS; i++) {
    String base = "u" + String(i) + "_";
    preferences.putBool((base + "used").c_str(), users[i].used);
    if (users[i].used) {
      preferences.putString((base + "name").c_str(), users[i].username);
      preferences.putString((base + "pass").c_str(), users[i].password);
      preferences.putString((base + "role").c_str(), users[i].role);
      preferences.putString((base + "last").c_str(), users[i].lastLogin);
    }
  }

  preferences.end();
}

void loadUsersFromPrefs() {
  initUsersArray();

  preferences.begin("users", true);
  int cnt = preferences.getInt("count", 0);
  primaryAdminIndex = preferences.getInt("primary", 0);

  if (cnt == 0) {
    String adminUser = getUsername();
    String adminPass = getPassword();
    users[0].username  = adminUser;
    users[0].password  = adminPass;
    users[0].role      = "admin";
    users[0].lastLogin = "";
    users[0].used      = true;
    primaryAdminIndex  = 0;
    preferences.end();
    saveUsersToPrefs();
    return;
  }

  for (int i = 0; i < MAX_USERS; i++) {
    String base = "u" + String(i) + "_";
    bool used = preferences.getBool((base + "used").c_str(), false);
    if (!used) continue;
    users[i].used      = true;
    users[i].username  = preferences.getString((base + "name").c_str(), "");
    users[i].password  = preferences.getString((base + "pass").c_str(), "");
    users[i].role      = preferences.getString((base + "role").c_str(), "viewer");
    users[i].lastLogin = preferences.getString((base + "last").c_str(), "");
  }

  preferences.end();
}

int findUserIndex(const String &username) {
  for (int i = 0; i < MAX_USERS; i++) {
    if (users[i].used && users[i].username == username) return i;
  }
  return -1;
}

int findFreeUserSlot() {
  for (int i = 0; i < MAX_USERS; i++) {
    if (!users[i].used) return i;
  }
  return -1;
}

//تابع پردازش SMS
void processSMS(String sms) {

  sms.trim();
  Serial.println("SMS: " + sms);

  // امنیت (شماره خودت رو بذار)
  //if (sms.indexOf("+989121792668") == -1) return;

  // ---- رله ها ----
  if (sms.indexOf("رله1 روشن") != -1) {
    setRelay(1, true);
    sendSMS("+989121792668", "رله 1 روشن شد");
  }

  if (sms.indexOf("رله1 خاموش") != -1) {
    setRelay(1, false);
    sendSMS("+989121792668", "رله 1 خاموش شد");
  }

  // ---- پورت ها ----
  if (sms.indexOf("پورت1 روشن") != -1) {
    setPort(1, true);
    sendSMS("+989121792668", "پورت 1 روشن شد");
  }

  if (sms.indexOf("پورت1 خاموش") != -1) {
    setPort(1, false);
    sendSMS("+989121792668", "پورت 1 خاموش شد");
  }

  // وضعیت کلی
  if (sms.indexOf("وضعیت") != -1) {
    sendSMS("+989121792668", getStatus());
  }
}

// تابع ارسال SMS
void sendSMS(String number, String text) {

  sim800.println("AT+CMGF=1");
  delay(200);

  sim800.print("AT+CMGS=\"");
  sim800.print(number);
  sim800.println("\"");

  delay(200);
  sim800.print(text);
  delay(200);

  sim800.write(26);
}

void setRelay(int num, bool state) {

  if (num < 1 || num > 8) return;

  // اگر وضعیت همونه → کاری نکن
  if (relayState[num - 1] == state) {
    Serial.println("Relay " + String(num) + " already in this state");
    return;
  }

  relayState[num - 1] = state;

  // 👇 اینجا وصلش کن به PCA9555 واقعی
  // مثال فرضی:
  // pca1.digitalWrite(pin, state);

  Serial.println("Relay " + String(num) + (state ? " ON" : " OFF"));
}

void setPort(int num, bool state) {

  if (num < 1 || num > 24) return;

  if (relayState[num - 1] == state) {
    Serial.println("Port " + String(num) + " already set");
    return;
  }

  relayState[num - 1] = state;

  // 👇 اتصال به PCA9555
  // pcaX.digitalWrite(pin, state);

  Serial.println("Port " + String(num) + (state ? " ON" : " OFF"));
}

String getStatus() {
  String status = "";

  for (int i = 0; i < RELAY_CH_COUNT; i++) {
    status += "R";
    status += String(i + 1);
    status += ": ";
    status += (relayState[i] ? "ON" : "OFF");
    status += "\n";
  }

  return status;
}

// ---------------------------------------------------------------------
// setup & loop
// ---------------------------------------------------------------------
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\nBooting...");

  pinMode(W5500_RST, OUTPUT);

  // کنترل شارژر DC
  pinMode(RL_DC2OUT, OUTPUT);
  loadChargerConfig();
  applyChargerGpio();

  digitalWrite(W5500_RST, LOW);
  delay(200);
  digitalWrite(W5500_RST, HIGH);
  delay(200);

  // Watchdog init
  esp_task_wdt_config_t wdt_config = {
    .timeout_ms = 30000,     // 30 ثانیه
    .idle_core_mask = (1 << portNUM_PROCESSORS) - 1, 
    .trigger_panic = true
  };

  esp_task_wdt_init(&wdt_config);
  esp_task_wdt_add(NULL);

// SIM 800
sim800.begin(9600, SERIAL_8N1, SIM800_RX, SIM800_TX);
delay(1000);
sim800.println("AT");
delay(500);
sim800.println("AT+CMGF=1");  // text mode
delay(500);
sim800.println("AT+CNMI=1,2,0,0,0");  // دریافت مستقیم SMS
delay(500);

// ESP2 link on UART1 (GPIO25/26)
esp2Serial.begin(115200, SERIAL_8N1, ESP2_UART_RX, ESP2_UART_TX);
esp2Serial.setTimeout(0);

esp2InitLink();

  Wire.begin(21, 22);
  initRelays();

  hspi.begin(14, 4, 13, SD_CS);
  if (SD.begin(SD_CS, hspi)) {
    Serial.println("SD ready");
    ensureRelayLogHeader();
    loadTooltipsFromFile();
  } else {
    Serial.println("SD fail");
  }

  loadWifiConfig();
  loadEthConfig();
  loadNtpConfig();
  loadCustomerConfig();
  loadUsersFromPrefs();

  ethernetBeginFromConfig();
  Udp.begin(8888);

  WiFi.mode(WIFI_AP);
  WiFi.setSleep(false);
  if (WiFi.softAP(wifiCfg.ssid.c_str(), wifiCfg.pass.c_str())) {
    Serial.print("AP SSID: ");
    Serial.println(wifiCfg.ssid);
    Serial.print("AP IP: ");
    Serial.println(WiFi.softAPIP());
  } else {
    Serial.println("AP start failed!");
  }
  wifiServer.begin();

  configTime(ntpCfg.gmtOffsetSec, ntpCfg.daylightOffsetSec,
             ntpCfg.server1.c_str(), ntpCfg.server2.c_str());

  Serial.print("Default admin user: ");
  Serial.println(getUsername());

}

// ================= ESP2 LINK PROTOCOL (transport-independent) =================
namespace Esp2Link {

static const uint8_t SOF1 = 0xA5;
static const uint8_t SOF2 = 0x5A;
static const uint8_t VER  = 0x01;

enum MsgType : uint8_t {
  MSG_PING      = 0x01,
  MSG_PONG      = 0x02,
  MSG_TELEM_REQ = 0x10,
  MSG_TELEM_RSP = 0x11,
  MSG_ACK       = 0x7E,
  MSG_NACK      = 0x7F,
};

enum Flags : uint8_t {
  FL_ACK_REQ = 0x01,
};

struct Frame {
  uint8_t ver;
  uint8_t type;
  uint8_t seq;
  uint8_t flags;
  uint16_t len;
  uint8_t payload[256];   // برای دمو کافی؛ بعداً برای OTA بزرگ می‌کنیم
  uint16_t crc;
};

// CRC16-CCITT-FALSE (poly 0x1021, init 0xFFFF)
static uint16_t crc16_ccitt_false(const uint8_t* data, size_t len) {
  uint16_t crc = 0xFFFF;
  for (size_t i = 0; i < len; i++) {
    crc ^= (uint16_t)data[i] << 8;
    for (int b = 0; b < 8; b++) {
      if (crc & 0x8000) crc = (crc << 1) ^ 0x1021;
      else crc <<= 1;
    }
  }
  return crc;
}

static void writeU16LE(Stream& s, uint16_t v) {
  s.write((uint8_t)(v & 0xFF));
  s.write((uint8_t)((v >> 8) & 0xFF));
}

static uint16_t readU16LE(const uint8_t* p) {
  return (uint16_t)p[0] | ((uint16_t)p[1] << 8);
}

class Link {
public:
  explicit Link(Stream& io) : _io(io) {}

  void begin() {
    _seqTx = 0;
    _lastRxMs = millis();
  }

  // Call frequently in loop() to parse incoming frames.
  bool poll(Frame& out) {
    while (_io.available()) {
      int b = _io.read();
      if (b < 0) break;
      if (_parseByte((uint8_t)b, out)) {
        _lastRxMs = millis();
        return true;
      }
    }
    return false;
  }

  // Send frame (no waiting)
  void send(uint8_t type, const uint8_t* payload, uint16_t len, uint8_t flags = 0, uint8_t seqOverride = 0xFF) {
    uint8_t seq = (seqOverride == 0xFF) ? _seqTx++ : seqOverride;

    // header: SOF1 SOF2 VER TYPE SEQ FLAGS LEN(2)
    uint8_t hdr[8];
    hdr[0] = SOF1;
    hdr[1] = SOF2;
    hdr[2] = VER;
    hdr[3] = type;
    hdr[4] = seq;
    hdr[5] = flags;
    hdr[6] = (uint8_t)(len & 0xFF);
    hdr[7] = (uint8_t)((len >> 8) & 0xFF);

    // CRC on [VER..LEN..PAYLOAD]
    // create temp buffer for crc calc
    uint8_t crcBuf[6 + 256]; // VER..LEN (6 bytes) + payload (max 256 here)
    crcBuf[0] = hdr[2]; // VER
    crcBuf[1] = hdr[3]; // TYPE
    crcBuf[2] = hdr[4]; // SEQ
    crcBuf[3] = hdr[5]; // FLAGS
    crcBuf[4] = hdr[6]; // LEN L
    crcBuf[5] = hdr[7]; // LEN H
    for (uint16_t i = 0; i < len && i < 256; i++) crcBuf[6 + i] = payload[i];

    uint16_t crc = crc16_ccitt_false(crcBuf, 6 + len);

    _io.write(hdr, 8);
    if (len) _io.write(payload, len);
    writeU16LE(_io, crc);
  }

  // Send and wait for ACK/NACK for same seq
  bool sendWithAck(uint8_t type, const uint8_t* payload, uint16_t len, uint32_t timeoutMs = 300, int retries = 3) {
    uint8_t seq = _seqTx; // seq used by send()
    for (int attempt = 0; attempt < retries; attempt++) {
      send(type, payload, len, FL_ACK_REQ, 0xFF); // seq auto increments
      seq = (uint8_t)(seq); // first seq
      // after send, seqTx has incremented. The sent seq is (seqTx-1)
      uint8_t sentSeq = (uint8_t)(_seqTx - 1);

      uint32_t t0 = millis();
      while (millis() - t0 < timeoutMs) {
        Frame fr;
        if (poll(fr)) {
          // auto-ack remote requests if needed
          if (fr.flags & FL_ACK_REQ) {
            sendAck(fr.seq);
          }

          if (fr.type == MSG_ACK && fr.seq == sentSeq) return true;
          if (fr.type == MSG_NACK && fr.seq == sentSeq) break; // retry
        }
        delay(1);
      }
      // retry
    }
    return false;
  }

  void sendAck(uint8_t seq) {
    send(MSG_ACK, nullptr, 0, 0, seq);
  }
  void sendNack(uint8_t seq) {
    send(MSG_NACK, nullptr, 0, 0, seq);
  }

  uint32_t lastRxAgeMs() const { return millis() - _lastRxMs; }

private:
  Stream& _io;
  uint8_t _seqTx = 0;
  uint32_t _lastRxMs = 0;

  // parser state
  uint8_t _st = 0;
  uint8_t _hdr[6]; // VER,TYPE,SEQ,FLAGS,LENL,LENH
  uint16_t _need = 0;
  uint16_t _pos = 0;
  uint8_t _payload[256];
  uint8_t _crcBytes[2];

  bool _parseByte(uint8_t b, Frame& out) {
    switch (_st) {
      case 0: // SOF1
        if (b == SOF1) _st = 1;
        return false;
      case 1: // SOF2
        if (b == SOF2) { _st = 2; _pos = 0; }
        else _st = 0;
        return false;
      case 2: // header 6 bytes
        _hdr[_pos++] = b;
        if (_pos == 6) {
          if (_hdr[0] != VER) { _st = 0; return false; }
          _need = readU16LE(&_hdr[4]);
          if (_need > 256) { _st = 0; return false; }
          _pos = 0;
          _st = (_need > 0) ? 3 : 4;
        }
        return false;
      case 3: // payload
        _payload[_pos++] = b;
        if (_pos == _need) { _pos = 0; _st = 4; }
        return false;
      case 4: // CRC16 2 bytes
        _crcBytes[_pos++] = b;
        if (_pos == 2) {
          uint16_t rxCrc = readU16LE(_crcBytes);

          uint8_t crcBuf[6 + 256];
          for (int i = 0; i < 6; i++) crcBuf[i] = _hdr[i];
          for (uint16_t i = 0; i < _need; i++) crcBuf[6 + i] = _payload[i];
          uint16_t calc = crc16_ccitt_false(crcBuf, 6 + _need);

          _st = 0;
          if (calc != rxCrc) return false;

          out.ver = _hdr[0];
          out.type = _hdr[1];
          out.seq = _hdr[2];
          out.flags = _hdr[3];
          out.len = _need;
          for (uint16_t i = 0; i < _need; i++) out.payload[i] = _payload[i];
          out.crc = rxCrc;
          return true;
        }
        return false;
      default:
        _st = 0;
        return false;
    }
  }
};

} // namespace Esp2Link
