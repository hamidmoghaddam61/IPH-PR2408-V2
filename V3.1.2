// Tooltip helpers
// ---------------------------------------------------------------------
void initTooltipArrays() {
  for (int i = 0; i < 24; i++) {
    portTooltips[i].type = 'P';
    portTooltips[i].index = i + 1;
    for (int j = 0; j < 5; j++) portTooltips[i].texts[j] = "";
  }
  for (int i = 0; i < 8; i++) {
    relayTooltips[i].type = 'R';
    relayTooltips[i].index = i + 1;
    for (int j = 0; j < 5; j++) relayTooltips[i].texts[j] = "";
  }
}

void loadTooltipsFromFile() {
  initTooltipArrays();

  if (!SD.exists("/tooltips.txt")) {
    Serial.println("tooltips.txt not found, using defaults.");
    return;
  }

  File f = SD.open("/tooltips.txt", FILE_READ);
  if (!f) {
    Serial.println("Failed to open tooltips.txt");
    return;
  }

  String line;
  while (f.available()) {
    char c = f.read();
    if (c == '\n') {
      line.trim();
      if (line.length() > 0) {
        char type = line.charAt(0); // P یا R
        int sep1 = line.indexOf('|');
        if (sep1 > 1) {
          int idx = line.substring(1, sep1).toInt();
          if (idx > 0) {
            String rest = line.substring(sep1 + 1);
            String parts[5];
            int pCount = 0;
            int start = 0;
            while (start < rest.length() && pCount < 5) {
              int p = rest.indexOf('|', start);
              if (p < 0) p = rest.length();
              parts[pCount++] = rest.substring(start, p);
              start = p + 1;
            }

            if (type == 'P' && idx >= 1 && idx <= 24) {
              TooltipEntry &e = portTooltips[idx - 1];
              for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
            } else if (type == 'R' && idx >= 1 && idx <= 8) {
              TooltipEntry &e = relayTooltips[idx - 1];
              for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
            }
          }
        }
      }
      line = "";
    } else {
      line += c;
    }
  }

  line.trim();
  if (line.length() > 0) {
    char type = line.charAt(0);
    int sep1 = line.indexOf('|');
    if (sep1 > 1) {
      int idx = line.substring(1, sep1).toInt();
      if (idx > 0) {
        String rest = line.substring(sep1 + 1);
        String parts[5];
        int pCount = 0;
        int start = 0;
        while (start < rest.length() && pCount < 5) {
          int p = rest.indexOf('|', start);
          if (p < 0) p = rest.length();
          parts[pCount++] = rest.substring(start, p);
          start = p + 1;
        }
        if (type == 'P' && idx >= 1 && idx <= 24) {
          TooltipEntry &e = portTooltips[idx - 1];
          for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
        } else if (type == 'R' && idx >= 1 && idx <= 8) {
          TooltipEntry &e = relayTooltips[idx - 1];
          for (int i = 0; i < 5; i++) e.texts[i] = (i < pCount ? parts[i] : "");
        }
      }
    }
  }

  f.close();
  Serial.println("Tooltips loaded.");
}

void saveTooltipsToFile() {
  SD.remove("/tooltips.txt");
  File f = SD.open("/tooltips.txt", FILE_WRITE);
  if (!f) {
    Serial.println("Failed to open tooltips.txt for write");
    return;
  }

  for (int i = 0; i < 24; i++) {
    TooltipEntry &e = portTooltips[i];
    bool any = false;
    for (int j = 0; j < 5; j++) {
      if (e.texts[j].length()) { any = true; break; }
    }
    if (!any) continue;

    f.print('P');
    f.print(e.index);
    f.print('|');
    for (int j = 0; j < 5; j++) {
      if (j > 0) f.print('|');
      f.print(e.texts[j]);
    }
    f.println();
  }

  for (int i = 0; i < 8; i++) {
    TooltipEntry &e = relayTooltips[i];
    bool any = false;
    for (int j = 0; j < 5; j++) {
      if (e.texts[j].length()) { any = true; break; }
    }
    if (!any) continue;

    f.print('R');
    f.print(e.index);
    f.print('|');
    for (int j = 0; j < 5; j++) {
      if (j > 0) f.print('|');
      f.print(e.texts[j]);
    }
    f.println();
  }

  f.close();
  Serial.println("Tooltips saved.");
}

// ---------------------------------------------------------------------
// SD / ارسال فایل
// ---------------------------------------------------------------------
void sendFile(Stream &client, const char* path, const char* mime) {
  File f = SD.open(path, FILE_READ);
  if (!f) {
    client.println("HTTP/1.1 404 Not Found");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Cache-Control: no-store, max-age=0");
    client.println("Pragma: no-cache");
    client.println("Expires: 0");
    client.println("Connection: close");
    client.println();
    client.print("File not found: ");
    client.println(path);
    return;
  }

  client.println("HTTP/1.1 200 OK");
  client.print("Content-Type: ");
  client.println(mime);
  client.println("Cache-Control: no-store");     // برای تست، جلوی کش‌های عجیب iOS را می‌گیرد
  client.println("Connection: close");
  client.println();

  static uint8_t buf[1024]; // static => روی stack فشار نمی‌آورد
  while (true) {
    int n = f.read(buf, sizeof(buf));
    if (n <= 0) break;
    client.write(buf, n);

    // مهم: جلوگیری از WDT در iOS/Safari
    esp_task_wdt_reset();
    delay(0); // یا yield()
  }

  f.close();
}

const char* guessMimeFromPath(const String &path) {
  if (path.endsWith(".html")) return "text/html; charset=utf-8";
  if (path.endsWith(".css"))  return "text/css; charset=utf-8";
  if (path.endsWith(".js"))   return "application/javascript; charset=utf-8";
  if (path.endsWith(".json")) return "application/json; charset=utf-8";
  if (path.endsWith(".png"))  return "image/png";
  if (path.endsWith(".svg"))  return "image/svg+xml";
  if (path.endsWith(".ico"))  return "image/x-icon";
  return "application/octet-stream";
}

