    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("ERROR:در این نسخه، آپدیت Firmware فقط از طریق endpoint خام /api/uploadFirmwareRaw (مثلاً با curl) پشتیبانی می‌شود.");
}

// OTA ساده: بدنه باینری مستقیم (بدون multipart)
// استفاده با curl:
//   curl -X POST -H "Content-Type: application/octet-stream" --data-binary @firmware.bin http://IP-ESP/api/uploadFirmwareRaw
void handleFirmwareRaw(Stream &client, const String &header, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  // Content-Length را از header می‌خوانیم (اگر نبود، از طول body استفاده می‌کنیم)
  String clKey = "Content-Length:";
  int clPos = header.indexOf(clKey);
  int contentLen = body.length();
  if (clPos >= 0) {
    int lineEnd = header.indexOf("\r\n", clPos);
    if (lineEnd < 0) lineEnd = header.length();
    String clStr = header.substring(clPos + clKey.length(), lineEnd);
    clStr.trim();
    int v = clStr.toInt();
    if (v > 0) contentLen = v;
  }

  Serial.print("RAW firmware upload, body size=");
  Serial.println(body.length());
  Serial.print("Content-Length=");
  Serial.println(contentLen);

  if (contentLen <= 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:Content-Length نامعتبر است.");
    return;
  }

  if (!Update.begin(contentLen)) {
    Serial.println("Update.begin failed");
    client.println("HTTP/1.1 500 Internal Server Error");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:Update.begin failed");
    return;
  }

  int remaining = contentLen;

  // 1) هرچه در body هست، بنویسیم
  if (body.length() > 0) {
    int chunk = (body.length() > remaining) ? remaining : body.length();
    String chunkStr = body.substring(0, chunk);
    size_t written = Update.write((uint8_t*)chunkStr.c_str(), chunk);
    if (written != (size_t)chunk) {
      Serial.println("Update.write failed on first chunk");
      Update.abort();
      client.println("HTTP/1.1 500 Internal Server Error");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:Update.write failed");
      return;
    }
    remaining -= chunk;
  }

  // 2) اگر هنوز بایتی مانده، مستقیم از client بخوانیم (بایت به بایت – سازگار با Stream)
  while (remaining > 0) {
    if (!client.available()) {
      delay(1);
      continue;
    }
    int c = client.read();
    if (c < 0) {
      // داده زودتر از حد انتظار تمام شده
      Serial.println("Client closed before all data received");
      Update.abort();
      client.println("HTTP/1.1 400 Bad Request");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:داده کامل دریافت نشد.");
      return;
    }
    uint8_t b = (uint8_t)c;
    size_t w = Update.write(&b, 1);
    if (w != 1) {
      Serial.println("Update.write failed in stream loop");
      Update.abort();
      client.println("HTTP/1.1 500 Internal Server Error");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:Update.write failed");
      return;
    }
    remaining--;
  }

  if (!Update.end(true)) {
    Serial.print("Update.end failed, error=");
    Serial.println(Update.errorString());
    client.println("HTTP/1.1 500 Internal Server Error");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:Update.end failed");
    return;
  }

  Serial.println("RAW Update success, reboot required.");

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:Firmware uploaded via RAW. لطفاً دستگاه را ریبوت کنید.");
}

// ---------------------------------------------------------------------
// آپلود فایل وب روی SD
// Endpoint: POST /api/uploadWebFile?name=/dashboard.html&key=1234
// بدنه‌ی درخواست: باینری خام فایل (application/octet-stream)
// ---------------------------------------------------------------------
void handleUploadWebFile(Stream &client,
                         const String &header,
                         const String &body,
                         const String &firstLine)
{
  // 1) چک key ساده (مثل OTA)
  if (firstLine.indexOf("key=1234") < 0) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:کلید آپلود وب نامعتبر است.");
    return;
  }

  // 2) گرفتن نام فایل از query string
  // firstLine شبیه است به:
  // "POST /api/uploadWebFile?name=/dashboard.html&key=1234 HTTP/1.1"
  int pathStart = firstLine.indexOf(' ');
  int pathEnd   = firstLine.indexOf(' ', pathStart + 1);
  if (pathStart < 0 || pathEnd < 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:خطا در تجزیه firstLine.");
    return;
  }
  String pathPart = firstLine.substring(pathStart + 1, pathEnd); // "/api/uploadWebFile?name=...&key=..."
  int qPos = pathPart.indexOf('?');
  String query = (qPos >= 0) ? pathPart.substring(qPos + 1) : "";

  String fileName = "";
  if (query.length() > 0) {
    // query به شکل name=/x.html&key=1234
    int nPos = query.indexOf("name=");
    if (nPos >= 0) {
      int start = nPos + 5;
      int amp   = query.indexOf('&', start);
      if (amp < 0) amp = query.length();
      fileName = query.substring(start, amp);
    }
  }

  if (fileName.length() == 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:پارامتر name یافت نشد.");
    return;
  }

  // اطمینان از اینکه با / شروع می‌شود و چیزی خطرناک مثل .. ندارد
  if (!fileName.startsWith("/")) fileName = "/" + fileName;
  if (fileName.indexOf("..") >= 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:نام فایل نامعتبر است.");
    return;
  }

  Serial.print("Upload web file to: ");
  Serial.println(fileName);

  // 3) تعیین طول داده (مثل OTA)
  String clKey = "Content-Length:";
  int clPos = header.indexOf(clKey);
  int contentLen = body.length();
  if (clPos >= 0) {
    int lineEnd = header.indexOf("\r\n", clPos);
    if (lineEnd < 0) lineEnd = header.length();
    String clStr = header.substring(clPos + clKey.length(), lineEnd);
    clStr.trim();
    int v = clStr.toInt();
    if (v > 0) contentLen = v;
  }

  if (contentLen <= 0) {
    client.println("HTTP/1.1 400 Bad Request");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:Content-Length نامعتبر است.");
    return;
  }

  if (!SD.begin(SD_CS, hspi)) {
    client.println("HTTP/1.1 500 Internal Server Error");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:SD در دسترس نیست.");
    return;
  }

  // 4) باز کردن فایل برای نوشتن
  SD.remove(fileName);
  File f = SD.open(fileName, FILE_WRITE);
  if (!f) {
    client.println("HTTP/1.1 500 Internal Server Error");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:باز کردن فایل برای نوشتن ناموفق بود.");
    return;
  }

  int remaining = contentLen;

  // 4-الف) هرچه در body هست، بنویس
  if (body.length() > 0) {
    int chunk = (body.length() > remaining) ? remaining : body.length();
    if (chunk > 0) {
      f.write((const uint8_t*)body.c_str(), chunk);
      remaining -= chunk;
    }
  }

  // 4-ب) بقیه داده را مستقیم از client بخوان
  while (remaining > 0) {
    if (!client.available()) {
      delay(1);
      continue;
    }
    int c = client.read();
    if (c < 0) {
      f.close();
      client.println("HTTP/1.1 400 Bad Request");
      client.println("Connection: close");
      client.println();
      client.print("ERROR:داده کامل دریافت نشد.");
      return;
    }
    uint8_t b = (uint8_t)c;
    f.write(&b, 1);
    remaining--;
  }

  f.close();

  Serial.print("Web file uploaded OK, size=");
  Serial.println(contentLen);

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:Web file uploaded.");
}


// ---------- Log: relay.log ----------
void ensureRelayLogHeader() {
  if (!SD.exists("/relay.log")) {
    File f = SD.open("/relay.log", FILE_WRITE);
    if (!f) return;
    f.println("DATETIME            |  USER       |  PORT/RELAY  |  ACTION        |  STATE");
    f.close();
  }
}

void appendRelayLog(const char* action, int ch) {
  File f = SD.open("/relay.log", FILE_APPEND);
  if (!f) return;

  time_t now = time(nullptr);
  struct tm t;
  localtime_r(&now, &t);

  char ts[32];
  snprintf(ts, sizeof(ts), "%04d-%02d-%02d %02d:%02d:%02d",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);

  const char* type;
  int index;
  if (ch >= 0 && ch < 24) {
    type = "PORT";
    index = ch + 1;
  } else {
    type = "RELAY";
    index = ch - 24 + 1;
  }

  String user = currentUser.length() ? currentUser : getUsername();
  const char* state = (relayState[ch] ? "ON" : "OFF");

  f.print(ts);
  f.print("  |  user=");
  f.print(user);
  f.print("  |  ");
  f.print(type);
  f.print("=");
  f.print(index);
  f.print("  |  action=");
  f.print(action);
  f.print("  |  state=");
  f.println(state);

  f.close();
}

