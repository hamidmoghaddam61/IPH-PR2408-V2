// ---------------------------------------------------------------------
// نقش کاربر فعلی
// ---------------------------------------------------------------------
bool isAdmin() {
  if (!isLoggedIn) return false;
  if (currentUser.length() == 0) {
    // حالت قدیمی: فقط ادمین اصلی وجود دارد
    return true;
  }
  int idx = findUserIndex(currentUser);
  if (idx < 0) return false;
  return (users[idx].role == "admin");
}

// ---------------------------------------------------------------------
// Login / Auth
// ---------------------------------------------------------------------
void handleLoginPost(Stream &client, const String &body) {
  String user = getField(body, "user");
  String pass = getField(body, "pass");

  loadUsersFromPrefs(); // مطمئن شو لیست کاربران به‌روز است

  int idx = findUserIndex(user);
  if (idx >= 0 && users[idx].password == pass) {
    isLoggedIn = true;
    currentUser = user;

    // ثبت آخرین ورود
    users[idx].lastLogin = formatCurrentTime();
    saveUsersToPrefs();

    client.println("HTTP/1.1 302 Found");
    client.println("Location: /dashboard");
    client.println("Connection: close");
    client.println();
  } else {
    isLoggedIn = false;
    currentUser = "";
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:نام کاربری یا رمز عبور اشتباه است");
  }
}

// save-admin (فقط ادمین می‌تواند)
void handleSaveAdmin(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
    return;
  }

  String user = getField(body, "admin_user");
  String pass1= getField(body, "admin_pass");
  String pass2= getField(body, "admin_pass2");

  if (user.isEmpty() || pass1.isEmpty() || pass2.isEmpty()) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:همه فیلدها ضروری هستند.");
    return;
  }
  if (pass1 != pass2) {
    client.println("HTTP/1.1 200 OK");
    client.println("Content-Type: text/plain; charset=utf-8");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:رمز و تکرار آن یکسان نیست.");
    return;
  }

  setAdminCredentials(user, pass1);

  // همچنین ادمین اصلی لیست کاربران را به‌روز می‌کنیم
  loadUsersFromPrefs();
  if (primaryAdminIndex < 0 || primaryAdminIndex >= MAX_USERS) primaryAdminIndex = 0;
  users[primaryAdminIndex].username  = user;
  users[primaryAdminIndex].password  = pass1;
  users[primaryAdminIndex].role      = "admin";
  users[primaryAdminIndex].used      = true;
  saveUsersToPrefs();

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/plain; charset=utf-8");
  client.println("Connection: close");
  client.println();
  client.print("OK:Admin updated. لطفاً برای اعمال، یک‌بار logout/login کنید.");
}

