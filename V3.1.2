      t.replace("\"", "\\\"");
      client.print(t);
      client.print("\"");
    }
    client.print("]}");
  }
  client.print("],\"relays\":[");
  for (int i = 0; i < 8; i++) {
    if (i > 0) client.print(",");
    TooltipEntry &e = relayTooltips[i];
    client.print("{\"id\":");
    client.print((int)e.index);
    client.print(",\"texts\":[");
    for (int j = 0; j < 5; j++) {
      if (j > 0) client.print(",");
      client.print("\"");
      String t = e.texts[j];
      t.replace("\\", "\\\\");
      t.replace("\"", "\\\"");
      client.print(t);
      client.print("\"");
    }
    client.print("]}");
  }
  client.print("]}");
}

void handleTooltipsSave(Stream &client, const String &body) {
  if (!isAdmin()) {
    client.println("HTTP/1.1 403 Forbidden");
    client.println("Connection: close");
    client.println();
    client.print("ERROR:دسترسی فقط برای ادمین مجاز است.");
