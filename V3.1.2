String getDeviceSerial() {
  uint64_t chipid = ESP.getEfuseMac();
  char buf[20];
  snprintf(buf, sizeof(buf), "%04X%08X",
           (uint16_t)(chipid >> 32), (uint32_t)chipid);
  return String(buf);
}

